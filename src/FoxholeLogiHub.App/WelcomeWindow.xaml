<Window x:Class="FoxholeLogiHub.App.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bienvenue"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" SizeToContent="Height" Width="440"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Border Background="{StaticResource B.Bg}" BorderBrush="{StaticResource B.Border}"
            BorderThickness="1" CornerRadius="12" Padding="28,26">
        <StackPanel>
            <Image Source="pack://application:,,,/Assets/logo.png" Width="76" Height="76"
                   RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center"/>
            <TextBlock Text="Bienvenue dans FoxholeLogiHub !" FontSize="19" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,14,0,4"/>
            <TextBlock Text="L'installation est terminée. Deux derniers réglages et c'est parti :"
                       Foreground="{StaticResource B.TextDim}" FontSize="12.5"
                       HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>

            <StackPanel Margin="14,20,0,0">
                <CheckBox x:Name="ChkDesktop" Content="Créer un raccourci sur le Bureau"
                          IsChecked="True" FontSize="13" Margin="0,0,0,10"/>
                <CheckBox x:Name="ChkStartup" Content="Lancer FoxholeLogiHub à l'ouverture de session Windows"
                          IsChecked="False" FontSize="13"
                          ToolTip="Pratique pour garder les alertes de stock et les comptes à rebours MPF actifs — modifiable à tout moment dans les Paramètres"/>
            </StackPanel>

            <Button Content="C'est parti  🚚" Click="OnGoClick" Margin="0,22,0,0"
                    Style="{StaticResource FlatButton}" Background="{StaticResource B.AccentDeep}"
                    Padding="0,11" FontSize="14"/>
            <TextBlock Text="Tout est modifiable plus tard dans l'onglet Paramètres."
                       Foreground="{StaticResource B.TextMuted}" FontSize="10.5"
                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
        </StackPanel>
    </Border>
</Window>

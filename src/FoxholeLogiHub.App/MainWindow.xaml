<Window x:Class="FoxholeLogiHub.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FoxholeLogiHub" Height="720" Width="980"
        Background="#FF1B1E24" Foreground="#FFE6E6E6"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#FF252A33"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9AA4B2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="#FF333A45"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
            <Setter Property="Margin" Value="0,0,14,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="NavButtonBase" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFC7CDD6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#FF15181E" Padding="14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="FoxholeLogiHub" FontSize="16" FontWeight="Bold"
                           Margin="4,4,0,18"/>

                <StackPanel DockPanel.Dock="Top">
                    <Button Click="OnNavDashboard">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDashboardActive}" Value="True">
                                        <Setter Property="Background" Value="#FF2C3340"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊  Dashboard" VerticalAlignment="Center"/>
                            <Border Background="#FFC03A3A" CornerRadius="9" Padding="6,1" Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding Stockpiles.HasCritical, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding Stockpiles.CriticalCount}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Button>
                    <Button Content="👤  Profil" Click="OnNavProfile">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProfileActive}" Value="True">
                                        <Setter Property="Background" Value="#FF2C3340"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="🫂  Amis" Click="OnNavFriends">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFriendsActive}" Value="True">
                                        <Setter Property="Background" Value="#FF2C3340"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="🛡  Régiment" Click="OnNavRegiment">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRegimentActive}" Value="True">
                                        <Setter Property="Background" Value="#FF2C3340"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="📦  Stockpiles" Click="OnNavStockpiles">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStockpilesActive}" Value="True">
                                        <Setter Property="Background" Value="#FF2C3340"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Click="OnNavResupply">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsResupplyActive}" Value="True">
                                        <Setter Property="Background" Value="#FF2C3340"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚚  Ravitaillement" VerticalAlignment="Center"/>
                            <Border Background="#FF2A6E8F" CornerRadius="9" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding Resupply.HasOpen, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding Resupply.OpenCount}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Button>
                    <Button Click="OnNavTaken">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTakenActive}" Value="True">
                                        <Setter Property="Background" Value="#FF2C3340"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛠  Prises en charge" VerticalAlignment="Center"/>
                            <Border Background="#FF2F6B43" CornerRadius="9" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding Resupply.HasTaken, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding Resupply.TakenActiveCount}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Présence en bas -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,0,0,2">
                    <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FF6B7280"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Friends.Connected}" Value="True">
                                        <Setter Property="Fill" Value="#FF4CC26A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding Friends.Status}" FontSize="10" Foreground="#FF9AA4B2"
                               TextWrapping="Wrap" Width="130"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Contenu -->
        <Grid Grid.Column="1" Margin="20">

            <!-- ====================== TABLEAU DE BORD ====================== -->
            <Grid Visibility="{Binding IsDashboardActive, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Tableau de bord" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Stockpiles.AlertsSummary}" Foreground="#FF9AA4B2" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Non connecté -->
                <TextBlock Grid.Row="1" Text="Connecte-toi avec Steam (onglet Amis) pour voir tes alertes."
                           Foreground="#FF6B7280" FontSize="14"
                           Visibility="{Binding Stockpiles.ShowAuthNeeded, Converter={StaticResource BoolToVis}}"/>

                <!-- Alertes -->
                <Grid Grid.Row="1" Visibility="{Binding Stockpiles.Authed, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Aucune alerte. Définis des seuils bas/critique sur tes items (onglet Stockpiles) pour les voir apparaître ici."
                               Foreground="#FF6B7280" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Top"
                               Visibility="{Binding Stockpiles.NoAlerts, Converter={StaticResource BoolToVis}}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding Stockpiles.HasAlerts, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding Stockpiles.AlertsView}">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,14,0,6">
                                                <TextBlock Text="📦" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="#FFE6E6E6"
                                                           VerticalAlignment="Center"/>
                                                <Border Background="#FF333A45" CornerRadius="9" Padding="7,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ItemCount}" Foreground="#FF9AA4B2" FontSize="11"/>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF20242C" CornerRadius="8" Margin="0,0,0,6">
                                        <Grid>
                                            <Border Width="4" HorizontalAlignment="Left" Background="{Binding SeverityBrush}"
                                                    CornerRadius="8,0,0,8"/>
                                            <DockPanel Margin="14,8,12,8">
                                                <Grid Width="36" Height="36" DockPanel.Dock="Left" Margin="0,0,12,0" VerticalAlignment="Center">
                                                    <Border Background="#FF1B1E24" CornerRadius="6"/>
                                                    <TextBlock Text="{Binding Initial}" Foreground="#FF9AA4B2" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <Image Source="{Binding Icon}" Width="34" Height="34"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Grid>
                                                <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding QuantityText}" FontWeight="Bold" FontSize="17"
                                                               Foreground="{Binding SeverityBrush}" TextAlignment="Right"/>
                                                    <TextBlock Text="{Binding ThresholdText}" Foreground="#FF6B7280" FontSize="10"
                                                               TextAlignment="Right"/>
                                                </StackPanel>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding SeverityBrush}" FontSize="11"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ====================== PROFIL ====================== -->
            <Grid Visibility="{Binding IsProfileActive, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Profil" FontSize="22" FontWeight="Bold" DockPanel.Dock="Left"/>
                    <Button Content="Rafraîchir" DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Style="{StaticResource FlatButton}" Click="OnRefreshClick"/>
                </DockPanel>

                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Width="96" Height="96" Margin="0,0,20,0">
                            <Ellipse Fill="{Binding FactionBrush}"/>
                            <Ellipse>
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding Avatar}" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Stroke="#33FFFFFF" StrokeThickness="2"/>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="PSEUDO" Style="{StaticResource Label}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="22" FontWeight="Bold" Foreground="White"
                                         Background="Transparent" BorderThickness="0" Padding="0"
                                         CaretBrush="White" MaxLength="40"/>
                                <Button Grid.Column="1" Content="Enregistrer" Style="{StaticResource FlatButton}"
                                        Margin="10,0,0,0" Click="OnSaveProfileClick"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Steam : " Foreground="#FF9AA4B2" FontSize="12"/>
                                <TextBlock Text="{Binding SteamId}" FontSize="12"/>
                                <TextBlock Text="  ·  pseudo Steam : " Foreground="#FF9AA4B2" FontSize="12"/>
                                <TextBlock Text="{Binding PersonaName}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="2" Background="{Binding FactionBrush}" CornerRadius="6"
                                Padding="14,10" VerticalAlignment="Center" Margin="20,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="FACTION" Foreground="#CCFFFFFF" FontSize="10"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Faction}" FontSize="16" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <UniformGrid Columns="3" Rows="1">
                        <StackPanel>
                            <TextBlock Text="DERNIER SERVEUR" Style="{StaticResource Label}"/>
                            <TextBlock Text="{Binding Server}" FontSize="15"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="LANGUE" Style="{StaticResource Label}"/>
                            <TextBlock Text="{Binding Language}" FontSize="15"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="GUERRES REJOINTES" Style="{StaticResource Label}"/>
                            <TextBlock Text="{Binding WarCount}" FontSize="15"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <Border Grid.Row="3" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock Text="Loadouts sauvegardés" FontSize="16" FontWeight="SemiBold"
                                   DockPanel.Dock="Top" Margin="0,0,0,12"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Loadouts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF2E343F" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold"
                                                           Margin="0,0,0,8"/>
                                                <ItemsControl ItemsSource="{Binding Equipment}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <DockPanel Margin="0,1">
                                                                <TextBlock Text="{Binding Slot}" Width="80"
                                                                           Foreground="#FF7FA8D9" FontSize="12"/>
                                                                <TextBlock Text="{Binding CodeName}" FontSize="13"/>
                                                                <TextBlock Text="{Binding Quantity, StringFormat='×{0}'}"
                                                                           DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                                           Foreground="#FF9AA4B2"/>
                                                            </DockPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <ItemsControl ItemsSource="{Binding Backpack}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <DockPanel Margin="0,1">
                                                                <TextBlock Text="sac" Width="80"
                                                                           Foreground="#FF8AA37A" FontSize="12"/>
                                                                <TextBlock Text="{Binding CodeName}" FontSize="13"/>
                                                                <TextBlock Text="{Binding Quantity, StringFormat='×{0}'}"
                                                                           DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                                           Foreground="#FF9AA4B2"/>
                                                            </DockPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <TextBlock Grid.Row="4" Text="{Binding Status}" Foreground="#FF9AA4B2" FontSize="12"/>
            </Grid>

            <!-- ====================== AMIS ====================== -->
            <Grid Visibility="{Binding IsFriendsActive, Converter={StaticResource BoolToVis}}">
              <Grid DataContext="{Binding Friends}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Amis" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>

                <!-- Mon code d'ami -->
                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <Grid>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Se déconnecter" VerticalAlignment="Top"
                                    HorizontalAlignment="Right" Style="{StaticResource FlatButton}"
                                    Background="#FF3A3030" Padding="10,5" Click="OnLogoutClick"/>
                            <StackPanel>
                                <TextBlock Text="MON CODE D'AMI" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding MyFriendCode, Mode=OneWay}" IsReadOnly="True"
                                         FontSize="26" FontWeight="Bold" Foreground="#FF7FA8D9"
                                         Background="Transparent" BorderThickness="0" Padding="0"
                                         FontFamily="Consolas"/>
                                <TextBlock Text="Partage ce code pour qu'on t'ajoute en ami."
                                           Foreground="#FF9AA4B2" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>

                <!-- Ajouter un ami -->
                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="AJOUTER UN AMI PAR CODE" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding AddCodeInput, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="15" Padding="8" Background="#FF1B1E24" Foreground="White"
                                     BorderBrush="#FF3A414C" BorderThickness="1" CaretBrush="White"
                                     VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="Envoyer" Style="{StaticResource FlatButton}"
                                    Margin="10,0,0,0" Click="OnSendRequestClick" IsEnabled="{Binding Connected}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Demandes reçues -->
                <Border Grid.Row="3" Style="{StaticResource Card}"
                        Visibility="{Binding HasRequests, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Demandes reçues" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding Requests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF33384A" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" Width="40" Height="40" Margin="0,0,12,0">
                                                <Ellipse Fill="{Binding FactionBrush}"/>
                                                <TextBlock Text="{Binding Initial}" Foreground="White"
                                                           FontWeight="Bold" FontSize="16"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Ellipse>
                                                    <Ellipse.Fill>
                                                        <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                            </Grid>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Faction}" FontSize="11" Foreground="#FF9AA4B2"/>
                                            </StackPanel>

                                            <Button Grid.Column="2" Content="Accepter" Style="{StaticResource FlatButton}"
                                                    Background="#FF2F6B43" Padding="12,6" Margin="0,0,8,0"
                                                    Click="OnAcceptRequestClick"/>
                                            <Button Grid.Column="3" Content="Refuser" Style="{StaticResource FlatButton}"
                                                    Background="#FF3A3030" Padding="12,6" Click="OnDeclineRequestClick"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Liste d'amis -->
                <Border Grid.Row="4" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Mes amis" FontSize="16" FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        <Grid DockPanel.Dock="Top">
                            <TextBlock Text="Aucun ami pour l'instant. Partage ton code ou ajoute un code ci-dessus."
                                       Foreground="#FF6B7280" FontSize="13"
                                       Visibility="{Binding HasNoFriends, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Friends}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF2E343F" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0" Width="40" Height="40" Margin="0,0,12,0">
                                                    <Ellipse Fill="{Binding FactionBrush}"/>
                                                    <TextBlock Text="{Binding Initial}" Foreground="White"
                                                               FontWeight="Bold" FontSize="16"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <Ellipse>
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <Ellipse Width="12" Height="12" HorizontalAlignment="Right"
                                                             VerticalAlignment="Bottom" Stroke="#FF2E343F"
                                                             StrokeThickness="2" Fill="{Binding StatusBrush}"/>
                                                </Grid>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Faction}" FontSize="11" Foreground="#FF9AA4B2"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="12"
                                                           Foreground="{Binding StatusBrush}" VerticalAlignment="Center"
                                                           Margin="0,0,12,0"/>

                                                <Button Grid.Column="3" Content="Retirer" Style="{StaticResource FlatButton}"
                                                        Background="#FF3A3030" Padding="10,5" Click="OnRemoveFriendClick"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
              </Grid>
            </Grid>

            <!-- ====================== RÉGIMENT ====================== -->
            <Grid Visibility="{Binding IsRegimentActive, Converter={StaticResource BoolToVis}}">
              <Grid DataContext="{Binding Regiment}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Régiment" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="#FF9AA4B2" FontSize="12" Margin="0,8,0,0"/>

                    <Grid>
                        <!-- État : connexion requise -->
                        <Border Style="{StaticResource Card}" VerticalAlignment="Top"
                                Visibility="{Binding ShowAuthNeeded, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Connecte-toi avec Steam (onglet Amis) pour créer ou gérer ton régiment."
                                       Foreground="#FF9AA4B2" FontSize="13" TextWrapping="Wrap"/>
                        </Border>

                        <!-- État : pas de régiment -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding ShowNoRegiment, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Border Style="{StaticResource Card}"
                                        Visibility="{Binding HasInvites, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Invitations reçues" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding Invites}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF33384A" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                        <DockPanel>
                                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                                <Button Content="Accepter" Style="{StaticResource FlatButton}"
                                                                        Background="#FF2F6B43" Padding="12,6" Margin="0,0,8,0" Click="OnAcceptRegInvite"/>
                                                                <Button Content="Refuser" Style="{StaticResource FlatButton}"
                                                                        Background="#FF3A3030" Padding="12,6" Click="OnDeclineRegInvite"/>
                                                            </StackPanel>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding FromDisplayName, StringFormat='Invité par {0}'}"
                                                                           FontSize="11" Foreground="#FF9AA4B2"/>
                                                            </StackPanel>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="CRÉER UN RÉGIMENT" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"
                                                 FontSize="15" Padding="8" Background="#FF1B1E24" Foreground="White"
                                                 BorderBrush="#FF3A414C" BorderThickness="1" CaretBrush="White"
                                                 ToolTip="Nom du régiment"/>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="Créer" Style="{StaticResource FlatButton}"
                                                    Background="#FF2A475E" Padding="16,8" Margin="10,0,0,0" Click="OnCreateRegiment"/>
                                            <TextBox Text="{Binding NewTag, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="15" Padding="8" Background="#FF1B1E24" Foreground="White"
                                                     BorderBrush="#FF3A414C" BorderThickness="1" CaretBrush="White"
                                                     ToolTip="Tag court, ex. FOX"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="REJOINDRE PAR CODE" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="Rejoindre" Style="{StaticResource FlatButton}"
                                                    Padding="16,8" Margin="10,0,0,0" Click="OnJoinRegiment"/>
                                            <TextBox Text="{Binding JoinCode, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="15" Padding="8" Background="#FF1B1E24" Foreground="White"
                                                     BorderBrush="#FF3A414C" BorderThickness="1" CaretBrush="White"
                                                     VerticalContentAlignment="Center"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- État : membre d'un régiment -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding ShowRegiment, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <!-- En-tête -->
                                <Border Style="{StaticResource Card}">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Top" HorizontalAlignment="Right">
                                            <Button Content="Régénérer le code" Style="{StaticResource FlatButton}"
                                                    Background="#FF333A45" Padding="10,5" Margin="0,0,0,6" Click="OnRegenCode"
                                                    Visibility="{Binding CanInvite, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="Supprimer le régiment" Style="{StaticResource FlatButton}"
                                                    Background="#FF5A2A2A" Padding="10,5" Click="OnDeleteRegiment"
                                                    Visibility="{Binding IAmOwner, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="Quitter le régiment"
                                                    Background="#FF3A3030" Padding="10,5" Click="OnLeaveRegiment">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FlatButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IAmOwner}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock FontSize="22" FontWeight="Bold">
                                                <Run Text="{Binding Name, Mode=OneWay}"/>
                                                <Run Text="{Binding Tag, Mode=OneWay, StringFormat=' [{0}]'}" Foreground="#FF9AA4B2"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Faction}" FontSize="12" Foreground="#FF7FA8D9" Margin="0,2,0,8"/>
                                            <TextBlock Text="CODE D'INVITATION" Style="{StaticResource Label}"/>
                                            <TextBox Text="{Binding InviteCode, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas"
                                                     FontSize="20" FontWeight="Bold" Foreground="#FF7FA8D9"
                                                     Background="Transparent" BorderThickness="0" Padding="0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- Membres -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Membres" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding Members}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF2E343F" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid Grid.Column="0" Width="38" Height="38" Margin="0,0,12,0">
                                                                <Ellipse Fill="{Binding FactionBrush}"/>
                                                                <TextBlock Text="{Binding Initial}" Foreground="White" FontWeight="Bold"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                <Ellipse><Ellipse.Fill><ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill"/></Ellipse.Fill></Ellipse>
                                                                <Ellipse Width="11" Height="11" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                                         Stroke="#FF2E343F" StrokeThickness="2" Fill="{Binding StatusBrush}"/>
                                                            </Grid>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding RoleBadge}" FontSize="11" Foreground="#FF9AA4B2"/>
                                                            </StackPanel>
                                                            <ComboBox Grid.Column="2" Width="120" Margin="0,0,8,0" VerticalAlignment="Center"
                                                                      ItemsSource="{Binding Roles}" DisplayMemberPath="Name" SelectedValuePath="Id"
                                                                      SelectedValue="{Binding RoleId, Mode=OneWay}" SelectionChanged="OnMemberRoleChanged"
                                                                      Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                            <Button Grid.Column="3" Content="Exclure" Style="{StaticResource FlatButton}"
                                                                    Background="#FF3A3030" Padding="10,5" Click="OnKickMember"
                                                                    Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Inviter des amis -->
                                <Border Style="{StaticResource Card}" Visibility="{Binding CanInvite, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Inviter des amis" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding Friends}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF2E343F" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                                        <DockPanel>
                                                            <Button DockPanel.Dock="Right" Content="Inviter" Style="{StaticResource FlatButton}"
                                                                    Background="#FF2A475E" Padding="12,5" Click="OnInviteFriendToReg"/>
                                                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="13"/>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Rôles & permissions -->
                                <Border Style="{StaticResource Card}" Visibility="{Binding CanManageRoles, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Rôles &amp; permissions" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding Roles}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF2E343F" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                                    <Button Content="Enregistrer" Style="{StaticResource FlatButton}"
                                                                            Background="#FF2F6B43" Padding="10,5" Margin="0,0,6,0" Click="OnSaveRole"/>
                                                                    <Button Content="Suppr." Style="{StaticResource FlatButton}"
                                                                            Background="#FF3A3030" Padding="10,5" Click="OnDeleteRole"
                                                                            Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}"/>
                                                                </StackPanel>
                                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" FontWeight="SemiBold"
                                                                         FontSize="14" Background="Transparent" Foreground="White" BorderThickness="0"
                                                                         CaretBrush="White" VerticalAlignment="Center"/>
                                                            </DockPanel>
                                                            <WrapPanel Margin="0,8,0,0">
                                                                <CheckBox Content="Membres" IsChecked="{Binding PMembers}"/>
                                                                <CheckBox Content="Rôles" IsChecked="{Binding PRoles}"/>
                                                                <CheckBox Content="Inviter" IsChecked="{Binding PInvite}"/>
                                                                <CheckBox Content="Régiment" IsChecked="{Binding PRegiment}"/>
                                                                <CheckBox Content="Alliances" IsChecked="{Binding PAlliances}"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <DockPanel Margin="0,4,0,0">
                                            <Button DockPanel.Dock="Right" Content="+ Rôle" Style="{StaticResource FlatButton}"
                                                    Padding="14,6" Margin="10,0,0,0" Click="OnCreateRole"/>
                                            <TextBox Text="{Binding NewRoleName, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="13" Padding="6" Background="#FF1B1E24" Foreground="White"
                                                     BorderBrush="#FF3A414C" BorderThickness="1" CaretBrush="White"
                                                     VerticalContentAlignment="Center" ToolTip="Nom du nouveau rôle"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Alliances -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Alliances" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding Alliances}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF2E343F" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                        <DockPanel>
                                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                                <Button Content="Accepter" Style="{StaticResource FlatButton}"
                                                                        Background="#FF2F6B43" Padding="10,5" Margin="0,0,6,0" Click="OnAcceptAlliance"
                                                                        Visibility="{Binding IsIncomingRequest, Converter={StaticResource BoolToVis}}"/>
                                                                <Button Content="Refuser" Style="{StaticResource FlatButton}"
                                                                        Background="#FF3A3030" Padding="10,5" Click="OnDeclineAlliance"
                                                                        Visibility="{Binding IsIncomingRequest, Converter={StaticResource BoolToVis}}"/>
                                                                <Button Content="Rompre" Style="{StaticResource FlatButton}"
                                                                        Background="#FF3A3030" Padding="10,5" Click="OnRemoveAlliance"
                                                                        Visibility="{Binding IsAccepted, Converter={StaticResource BoolToVis}}"/>
                                                            </StackPanel>
                                                            <Border DockPanel.Dock="Left" Width="6" CornerRadius="3" Margin="0,0,10,0"
                                                                    Background="{Binding FactionBrush}"/>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding StateText}" FontSize="11" Foreground="#FF9AA4B2"/>
                                                            </StackPanel>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <DockPanel Margin="0,4,0,0" Visibility="{Binding CanManageAlliances, Converter={StaticResource BoolToVis}}">
                                            <Button DockPanel.Dock="Right" Content="Proposer" Style="{StaticResource FlatButton}"
                                                    Background="#FF2A475E" Padding="14,6" Margin="10,0,0,0" Click="OnProposeAlliance"/>
                                            <TextBox Text="{Binding AllianceCode, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="13" Padding="6" Background="#FF1B1E24" Foreground="White"
                                                     BorderBrush="#FF3A414C" BorderThickness="1" CaretBrush="White"
                                                     VerticalContentAlignment="Center" ToolTip="Code d'invitation du régiment à allier"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </DockPanel>
              </Grid>
            </Grid>

            <!-- ====================== STOCKPILES ====================== -->
            <Grid Visibility="{Binding IsStockpilesActive, Converter={StaticResource BoolToVis}}">
              <Grid DataContext="{Binding Stockpiles}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Stockpiles" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="#FF9AA4B2" FontSize="12" Margin="0,8,0,0"/>
                    <Grid>
                        <Border Style="{StaticResource Card}" VerticalAlignment="Top"
                                Visibility="{Binding ShowAuthNeeded, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Connecte-toi avec Steam (onglet Amis) pour gérer les stockpiles."
                                       Foreground="#FF9AA4B2" FontSize="13" TextWrapping="Wrap"/>
                        </Border>
                        <Border Style="{StaticResource Card}" VerticalAlignment="Top"
                                Visibility="{Binding ShowNoRegiment, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Rejoins ou crée un régiment (onglet Régiment) : les stockpiles appartiennent au régiment."
                                       Foreground="#FF9AA4B2" FontSize="13" TextWrapping="Wrap"/>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding ShowStockpiles, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <!-- Formulaire création / édition -->
                                <Border Style="{StaticResource Card}" Visibility="{Binding ShowForm, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SubmitLabel}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="NOM" Style="{StaticResource Label}"/>
                                                <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14" Padding="7" Background="#FF1B1E24" Foreground="White"
                                                         BorderBrush="#FF3A414C" BorderThickness="1" CaretBrush="White"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="TYPE" Style="{StaticResource Label}"/>
                                                <ComboBox ItemsSource="{Binding Types}" DisplayMemberPath="Label" SelectedValuePath="Value"
                                                          SelectedValue="{Binding FormType}" Padding="6" FontSize="14"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="HEXAGONE" Style="{StaticResource Label}"/>
                                                <ComboBox IsEditable="True" Text="{Binding FormHex, UpdateSourceTrigger=PropertyChanged}"
                                                          ItemsSource="{Binding Hexes}" Padding="6" FontSize="14"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="LIEU (optionnel)" Style="{StaticResource Label}"/>
                                                <TextBox Text="{Binding FormTown, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14" Padding="7" Background="#FF1B1E24" Foreground="White"
                                                         BorderBrush="#FF3A414C" BorderThickness="1" CaretBrush="White"/>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,0,0,8"
                                                    Visibility="{Binding FormUsesCode, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="CODE (mot de passe du Port/Dépôt)" Style="{StaticResource Label}"/>
                                            <TextBox Text="{Binding FormCode, UpdateSourceTrigger=PropertyChanged}" MaxLength="8" Width="160"
                                                     HorizontalAlignment="Left" FontFamily="Consolas" FontSize="15" Padding="7"
                                                     Background="#FF1B1E24" Foreground="White" BorderBrush="#FF3A414C" BorderThickness="1" CaretBrush="White"/>
                                        </StackPanel>
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                <Button Content="Annuler" Style="{StaticResource FlatButton}" Background="#FF3A3030"
                                                        Padding="12,7" Margin="0,0,8,0" Click="OnCancelStockpileEdit"
                                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                                                <Button Content="{Binding SubmitLabel}" Style="{StaticResource FlatButton}"
                                                        Background="#FF2A475E" Padding="16,7" Click="OnSubmitStockpile"/>
                                            </StackPanel>
                                            <CheckBox Content="Public (visible par les alliés)" IsChecked="{Binding FormIsPublic}" VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Liste -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Stockpiles (les miens + ceux des alliés)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Aucun stockpile pour l'instant." Foreground="#FF6B7280" FontSize="13"
                                                   Visibility="{Binding HasNoStockpiles, Converter={StaticResource BoolToVis}}"/>
                                        <ItemsControl ItemsSource="{Binding Stockpiles}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF2E343F" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <Border DockPanel.Dock="Right" Background="{Binding VisibilityBrush}" CornerRadius="4"
                                                                        Padding="8,3" VerticalAlignment="Top">
                                                                    <TextBlock Text="{Binding VisibilityLabel}" Foreground="White" FontSize="11"/>
                                                                </Border>
                                                                <Button DockPanel.Dock="Right" Content="Items" Style="{StaticResource FlatButton}"
                                                                        Background="#FF333A45" Padding="10,4" Margin="0,0,8,0" VerticalAlignment="Top"
                                                                        Click="OnSelectStockpile"/>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold"/>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding TypeLabel}" Foreground="#FF7FA8D9" FontSize="12"/>
                                                                        <TextBlock Text="  ·  " Foreground="#FF6B7280" FontSize="12"/>
                                                                        <TextBlock Text="{Binding LocationLabel}" Foreground="#FF9AA4B2" FontSize="12"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </DockPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                                                        Visibility="{Binding HasCode, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="Code : " Foreground="#FF9AA4B2" FontSize="12" VerticalAlignment="Center"/>
                                                                <TextBox Text="{Binding Code, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas"
                                                                         FontSize="14" FontWeight="Bold" Foreground="#FF7FA8D9" Background="Transparent"
                                                                         BorderThickness="0" Padding="0"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding RegimentName, StringFormat='Régiment allié : {0}'}"
                                                                       Foreground="#FF8AA37A" FontSize="11" Margin="0,4,0,0"
                                                                       Visibility="{Binding ShowForeignRegiment, Converter={StaticResource BoolToVis}}"/>

                                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                                        Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}">
                                                                <Button Content="Modifier" Style="{StaticResource FlatButton}" Background="#FF333A45"
                                                                        Padding="10,4" Margin="0,0,6,0" Click="OnEditStockpile"/>
                                                                <Button Content="Supprimer" Style="{StaticResource FlatButton}" Background="#FF3A3030"
                                                                        Padding="10,4" Click="OnDeleteStockpile"/>
                                                            </StackPanel>

                                                            <StackPanel Margin="0,8,0,0"
                                                                        Visibility="{Binding ShowShareSection, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="Partager avec un allié :" Foreground="#FF9AA4B2" FontSize="11" Margin="0,0,0,4"/>
                                                                <ItemsControl ItemsSource="{Binding ShareTargets}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Content="{Binding ButtonText}" Background="{Binding ButtonBrush}"
                                                                                    Style="{StaticResource FlatButton}" Padding="10,4" Margin="0,0,6,6"
                                                                                    Click="OnToggleShare"/>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Détail : contenu (items) du stockpile sélectionné -->
                                <Border Style="{StaticResource Card}"
                                        Visibility="{Binding IsStockpileSelected, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
                                            <Button DockPanel.Dock="Right" Content="Fermer" Style="{StaticResource FlatButton}"
                                                    Background="#FF333A45" Padding="10,4" Click="OnCloseDetail"/>
                                            <TextBlock Text="{Binding SelectedName, StringFormat='Contenu — {0}'}"
                                                       FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </DockPanel>

                                        <Border Background="#FF22384A" CornerRadius="6" Padding="10" Margin="0,0,0,10"
                                                Visibility="{Binding SelectedCanManage, Converter={StaticResource BoolToVis}}">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="📷 Importer (capture)" Style="{StaticResource FlatButton}"
                                                        Background="#FF2A6E8F" Padding="14,6" Click="OnImportCapture"/>
                                                <TextBlock VerticalAlignment="Center" Foreground="#FFB8C4D0" FontSize="11" TextWrapping="Wrap"
                                                           Text="Remplissage auto (FIR) : ouvre le stockpile en VUE-CARTE en jeu, puis clique (4 s pour basculer) — ou appuie sur F8 directement en jeu. Compatible mods d'icônes."/>
                                            </DockPanel>
                                        </Border>

                                        <StackPanel Margin="0,0,0,12"
                                                    Visibility="{Binding SelectedCanManage, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="AJOUTER / MODIFIER (item · quantité · seuil bas · seuil critique)"
                                                       Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="Définir" Style="{StaticResource FlatButton}"
                                                        Background="#FF2A475E" Padding="14,6" Margin="6,0,0,0" Click="OnSetItem"/>
                                                <TextBox DockPanel.Dock="Right" Width="70" Margin="6,0,0,0"
                                                         Text="{Binding NewItemCritical, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14" Padding="6" Background="#FF1B1E24" Foreground="White"
                                                         BorderBrush="#FFC03A3A" BorderThickness="1" CaretBrush="White"
                                                         VerticalContentAlignment="Center" ToolTip="Seuil critique (🔴 ≤)"/>
                                                <TextBox DockPanel.Dock="Right" Width="70" Margin="6,0,0,0"
                                                         Text="{Binding NewItemLow, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14" Padding="6" Background="#FF1B1E24" Foreground="White"
                                                         BorderBrush="#FFC88A2E" BorderThickness="1" CaretBrush="White"
                                                         VerticalContentAlignment="Center" ToolTip="Seuil bas (🟠 ≤)"/>
                                                <TextBox DockPanel.Dock="Right" Width="80" Margin="6,0,0,0"
                                                         Text="{Binding NewItemQuantity, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14" Padding="6" Background="#FF1B1E24" Foreground="White"
                                                         BorderBrush="#FF3A414C" BorderThickness="1" CaretBrush="White"
                                                         VerticalContentAlignment="Center" ToolTip="Quantité (0 = retirer)"/>
                                                <ComboBox IsEditable="True" ItemsSource="{Binding ItemNames}" FontSize="14" Padding="6"
                                                          Text="{Binding NewItemName, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DockPanel>
                                        </StackPanel>

                                        <TextBlock Text="Aucun item. Ajoute-en ci-dessus ou via 📷 Importer." Foreground="#FF6B7280" FontSize="13"
                                                   Visibility="{Binding HasNoItems, Converter={StaticResource BoolToVis}}"/>
                                        <ItemsControl ItemsSource="{Binding ItemsView}">
                                            <ItemsControl.GroupStyle>
                                                <GroupStyle>
                                                    <GroupStyle.HeaderTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FF9AA4B2"
                                                                       FontSize="12" Margin="2,10,0,6"/>
                                                        </DataTemplate>
                                                    </GroupStyle.HeaderTemplate>
                                                    <GroupStyle.Panel>
                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                    </GroupStyle.Panel>
                                                </GroupStyle>
                                            </ItemsControl.GroupStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="158" Background="#FF2E343F" CornerRadius="8" Margin="0,0,8,8">
                                                        <Grid>
                                                            <Border Width="4" HorizontalAlignment="Left" Background="{Binding StatusBrush}"
                                                                    CornerRadius="8,0,0,8"/>
                                                            <StackPanel Margin="12,8,8,8">
                                                                <DockPanel>
                                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                                                                        <Button Content="ⓘ" Style="{StaticResource FlatButton}" Background="#FF2A3340"
                                                                                Padding="6,1" Margin="0,0,4,0" Click="OnItemDetails" FontSize="11"
                                                                                ToolTip="Détails / recette de craft"/>
                                                                        <Button Content="✎" Style="{StaticResource FlatButton}" Background="#FF333A45"
                                                                                Padding="6,1" Margin="0,0,4,0" Click="OnEditItem" FontSize="11"
                                                                                Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                                        <Button Content="×" Style="{StaticResource FlatButton}" Background="#FF3A3030"
                                                                                Padding="7,1" Click="OnRemoveItem" FontSize="11"
                                                                                Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                                    </StackPanel>
                                                                    <Grid Width="40" Height="40" HorizontalAlignment="Left">
                                                                        <Border Background="#FF1B1E24" CornerRadius="6"/>
                                                                        <TextBlock Text="{Binding Initial}" Foreground="#FF9AA4B2" FontWeight="Bold"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        <Image Source="{Binding Icon}" Width="38" Height="38" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                    </Grid>
                                                                </DockPanel>
                                                                <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#FFE6E6E6"
                                                                           TextWrapping="Wrap" Height="30" Margin="0,6,0,2"/>
                                                                <DockPanel>
                                                                    <Border DockPanel.Dock="Right" Background="{Binding StatusBrush}" CornerRadius="4"
                                                                            Padding="6,1" VerticalAlignment="Center"
                                                                            Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
                                                                        <TextBlock Text="{Binding StatusLabel}" Foreground="White" FontSize="10"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding QuantityText}" FontWeight="Bold" FontSize="18"
                                                                               Foreground="#FFE6E6E6"/>
                                                                </DockPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </DockPanel>

                <!-- ===== Fiche détaillée d'un item (gestion poussée : catégorie, caisse, recette) ===== -->
                <Border Background="#CC0A0C10" Visibility="{Binding HasItemDetail, Converter={StaticResource BoolToVis}}">
                    <Border Width="430" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Background="#FF1B1F27" CornerRadius="12" BorderBrush="#FF3A414C" BorderThickness="1"
                            DataContext="{Binding ItemDetail}">
                        <DockPanel>
                            <!-- En-tête -->
                            <Border DockPanel.Dock="Top" Background="#FF222834" CornerRadius="12,12,0,0">
                                <DockPanel Margin="16,14">
                                    <Button DockPanel.Dock="Right" Content="✕" Style="{StaticResource FlatButton}"
                                            Background="#FF333A45" Padding="9,3" VerticalAlignment="Top" Click="OnCloseItemDetail"/>
                                    <Grid Width="48" Height="48" DockPanel.Dock="Left" Margin="0,0,12,0" VerticalAlignment="Top">
                                        <Border Background="#FF12151B" CornerRadius="8"/>
                                        <TextBlock Text="{Binding Initial}" Foreground="#FF9AA4B2" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Image Source="{Binding Icon}" Width="44" Height="44" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Category}" Foreground="#FF9AA4B2" FontSize="12" Margin="0,1,0,0"/>
                                        <TextBlock Text="{Binding CaliberLabel}" Foreground="#FF7FA8D9" FontSize="11"
                                                   Visibility="{Binding HasCaliber, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <!-- Corps -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="16,12,16,16">
                                    <DockPanel Margin="0,0,0,12">
                                        <TextBlock Text="📦 Caisse" Foreground="#FF9AA4B2" FontSize="12" Width="90" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding CrateText}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                    </DockPanel>

                                    <TextBlock Text="{Binding RecipeHeader}" Style="{StaticResource Label}" Margin="0,0,0,6"
                                               Visibility="{Binding HasRecipe, Converter={StaticResource BoolToVis}}"/>
                                    <ItemsControl ItemsSource="{Binding Recipes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FF20242C" CornerRadius="8" Margin="0,0,0,8" Padding="10,8">
                                                    <StackPanel>
                                                        <DockPanel Margin="0,0,0,6">
                                                            <TextBlock DockPanel.Dock="Right" Text="{Binding OutputText}" Foreground="#FF6FCF8E"
                                                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                                                       Visibility="{Binding HasOutput, Converter={StaticResource BoolToVis}}"/>
                                                            <TextBlock Text="{Binding Header}" Foreground="#FFB8C4D0" FontSize="13" FontWeight="SemiBold"/>
                                                        </DockPanel>
                                                        <ItemsControl ItemsSource="{Binding Ingredients}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#FF252A33" CornerRadius="6" Margin="0,0,0,4" Padding="6,4">
                                                                        <DockPanel>
                                                                            <TextBlock DockPanel.Dock="Right" Text="{Binding QtyText}" Foreground="#FFE6B45A"
                                                                                       FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                                                            <Grid Width="26" Height="26" DockPanel.Dock="Left" Margin="0,0,8,0">
                                                                                <Border Background="#FF12151B" CornerRadius="5"/>
                                                                                <TextBlock Text="{Binding Initial}" Foreground="#FF9AA4B2" FontSize="10"
                                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                <Image Source="{Binding Icon}" Width="24" Height="24"/>
                                                                            </Grid>
                                                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                                                        </DockPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <TextBlock Text="{Binding MetaText}" Foreground="#FF9AA4B2" FontSize="11" Margin="0,2,0,0"
                                                                   Visibility="{Binding HasMeta, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="ℹ La MPF produit en lot (3/9/...) avec une remise de matériaux à volume."
                                               Foreground="#FF6B7280" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"
                                               Visibility="{Binding HasMpf, Converter={StaticResource BoolToVis}}"/>

                                    <TextBlock Text="{Binding NoRecipeText}" Foreground="#FF6B7280" FontSize="12" TextWrapping="Wrap"
                                               Visibility="{Binding NoRecipe, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Border>
              </Grid>
            </Grid>

            <!-- ====================== RAVITAILLEMENT ====================== -->
            <Grid Visibility="{Binding IsResupplyActive, Converter={StaticResource BoolToVis}}">
              <Grid DataContext="{Binding Resupply}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Ravitaillement" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Summary}" Foreground="#FF9AA4B2" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="Connecte-toi avec Steam (onglet Amis)." Foreground="#FF6B7280" FontSize="14"
                           Visibility="{Binding ShowAuthNeeded, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Grid.Row="1" Text="Rejoins un régiment pour gérer le ravitaillement." Foreground="#FF6B7280" FontSize="14"
                           Visibility="{Binding ShowNoRegiment, Converter={StaticResource BoolToVis}}"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding ShowResupply, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <!-- Nouvelle demande (multi-items) -->
                        <Border Background="#FF1B1E24" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="NOUVELLE DEMANDE (nom · hexagone · coordonnées · priorité, puis ajoute des items)"
                                           Style="{StaticResource Label}" Margin="0,0,0,8"/>
                                <DockPanel Margin="0,0,0,8">
                                    <ComboBox DockPanel.Dock="Right" Width="110" Margin="6,0,0,0" SelectedValuePath="Value"
                                              DisplayMemberPath="Label" SelectedValue="{Binding NewPriority}"
                                              ItemsSource="{Binding Priorities}" FontSize="14" Padding="6" ToolTip="Priorité"/>
                                    <TextBox DockPanel.Dock="Right" Width="120" Margin="6,0,0,0"
                                             Text="{Binding NewCoords, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" Padding="6" Background="#FF15181E" Foreground="White"
                                             BorderBrush="#FF3A414C" BorderThickness="1" CaretBrush="White"
                                             VerticalContentAlignment="Center" ToolTip="Coordonnées (ex. E5, 123x456)"/>
                                    <ComboBox DockPanel.Dock="Right" Width="180" Margin="6,0,0,0" IsEditable="True"
                                              ItemsSource="{Binding Hexes}" Text="{Binding NewHex, UpdateSourceTrigger=PropertyChanged}"
                                              FontSize="14" Padding="6" ToolTip="Hexagone"/>
                                    <TextBox Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="6"
                                             Background="#FF15181E" Foreground="White" BorderBrush="#FF3A414C" BorderThickness="1"
                                             CaretBrush="White" VerticalContentAlignment="Center" ToolTip="Nom de la demande"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Content="+ Ajouter l'item" Style="{StaticResource FlatButton}"
                                            Background="#FF333A45" Padding="12,6" Margin="6,0,0,0" Click="OnAddDraftItem"/>
                                    <TextBox DockPanel.Dock="Right" Width="80" Margin="6,0,0,0"
                                             Text="{Binding DraftItemQuantity, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" Padding="6" Background="#FF15181E" Foreground="White"
                                             BorderBrush="#FF3A414C" BorderThickness="1" CaretBrush="White"
                                             VerticalContentAlignment="Center" ToolTip="Quantité"/>
                                    <ComboBox IsEditable="True" ItemsSource="{Binding ItemNames}" FontSize="14" Padding="6"
                                              Text="{Binding DraftItemName, UpdateSourceTrigger=PropertyChanged}" ToolTip="Item à ajouter"/>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding DraftItems}" Margin="0,0,0,8"
                                              Visibility="{Binding HasDraft, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FF2A3038" CornerRadius="6" Margin="0,0,6,6" Padding="6,3">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="{Binding Icon}" Width="22" Height="22" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding QtyText}" Foreground="#FF7FA8D9" FontSize="12" FontWeight="Bold"
                                                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                    <Button Content="×" Style="{StaticResource FlatButton}" Background="#FF3A3030"
                                                            Padding="6,0" Margin="8,0,0,0" FontSize="11" Click="OnRemoveDraftItem"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Créer la demande" Style="{StaticResource FlatButton}"
                                            Background="#FF2A475E" Padding="14,6" Margin="6,0,0,0" Click="OnCreateResupply"/>
                                    <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" FontSize="13" Padding="6"
                                             Background="#FF15181E" Foreground="White" BorderBrush="#FF3A414C" BorderThickness="1"
                                             CaretBrush="White" VerticalContentAlignment="Center" ToolTip="Note (optionnel)"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Manques détectés -->
                        <StackPanel Margin="0,0,0,14" Visibility="{Binding HasNeeds, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="MANQUES DÉTECTÉS (items sous seuil dans tes stockpiles)"
                                       Style="{StaticResource Label}" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding Needs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF20242C" CornerRadius="6" Margin="0,0,0,5" Padding="8,5">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="+ Brouillon" Style="{StaticResource FlatButton}"
                                                        Background="#FF2A475E" Padding="10,3" Margin="6,0,0,0" FontSize="11"
                                                        Click="OnCreateFromNeed" VerticalAlignment="Center"
                                                        ToolTip="Ajouter ce manque à la demande en cours de création"/>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding DeficitText}" Foreground="{Binding DeficitBrush}"
                                                           FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                <Grid Width="30" Height="30" DockPanel.Dock="Left" Margin="0,0,10,0">
                                                    <Border Background="#FF12151B" CornerRadius="5"/>
                                                    <TextBlock Text="{Binding Initial}" Foreground="#FF9AA4B2" FontSize="11"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <Image Source="{Binding Icon}" Width="28" Height="28"/>
                                                </Grid>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13"/>
                                                    <TextBlock Text="{Binding LocationLabel}" Foreground="#FF9AA4B2" FontSize="10"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Demandes ouvertes -->
                        <TextBlock Text="DEMANDES OUVERTES" Style="{StaticResource Label}" Margin="0,0,0,6"
                                   Visibility="{Binding HasOpen, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="Aucune demande ouverte. Crée-en une ci-dessus, ou ajoute des manques au brouillon (+ Brouillon)."
                                   Foreground="#FF6B7280" FontSize="13"
                                   Visibility="{Binding NoOpen, Converter={StaticResource BoolToVis}}"/>
                        <ItemsControl ItemsSource="{Binding OpenRequests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF20242C" CornerRadius="8" Margin="0,0,0,8">
                                        <Grid>
                                            <Border Width="4" HorizontalAlignment="Left" Background="{Binding StatusBrush}" CornerRadius="8,0,0,8"/>
                                            <StackPanel Margin="14,10,12,10">
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                                                        <Border Background="{Binding StatusBrush}" CornerRadius="4" Padding="6,1" Margin="0,0,4,0">
                                                            <TextBlock Text="{Binding StatusLabel}" Foreground="White" FontSize="10"/></Border>
                                                        <Border Background="{Binding PriorityBrush}" CornerRadius="4" Padding="6,1"
                                                                Visibility="{Binding ShowPriority, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="{Binding PriorityLabel}" Foreground="White" FontSize="10"/></Border>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding LocationLabel, StringFormat='📍 {0}'}" Foreground="#FF9AA4B2" FontSize="11"/>
                                                    </StackPanel>
                                                </DockPanel>
                                                <ItemsControl ItemsSource="{Binding Items}" Margin="0,8,0,0">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#FF2A3038" CornerRadius="6" Margin="0,0,6,6" Padding="6,3">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Image Source="{Binding Icon}" Width="22" Height="22" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding QtyText}" Foreground="#FF7FA8D9" FontSize="12" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="{Binding Note}" Foreground="#FFB8C4D0" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                                           Visibility="{Binding HasNote, Converter={StaticResource BoolToVis}}"/>
                                                <DockPanel Margin="0,8,0,0">
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                        <Button Content="{Binding ClaimButtonText}" Background="{Binding ClaimButtonBrush}"
                                                                Style="{StaticResource FlatButton}" Padding="12,5" Margin="0,0,4,0" FontSize="11" Click="OnClaimResupply"/>
                                                        <Button Content="✓ Livré" Background="#FF2F6B43" Style="{StaticResource FlatButton}"
                                                                Padding="12,5" Margin="0,0,4,0" FontSize="11" Click="OnDoneResupply"/>
                                                        <Button Content="×" Background="#FF3A3030" Style="{StaticResource FlatButton}"
                                                                Padding="9,5" FontSize="11" Click="OnDeleteResupply"
                                                                Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding CreatedInfo}" Foreground="#FF6B7280" FontSize="10" VerticalAlignment="Center"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
              </Grid>
            </Grid>

            <!-- ====================== PRISES EN CHARGE ====================== -->
            <Grid Visibility="{Binding IsTakenActive, Converter={StaticResource BoolToVis}}">
              <Grid DataContext="{Binding Resupply}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Prises en charge" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Demandes prises par le régiment, avec le plan de production (crafts, récoltes, véhicules)."
                               Foreground="#FF9AA4B2" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>
                <TextBlock Grid.Row="1" Text="Connecte-toi avec Steam (onglet Amis)." Foreground="#FF6B7280" FontSize="14"
                           Visibility="{Binding ShowAuthNeeded, Converter={StaticResource BoolToVis}}"/>
                <Grid Grid.Row="1" Visibility="{Binding ShowResupply, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Aucune demande prise en charge. Va dans « Ravitaillement » et clique « Prendre en charge »."
                               Foreground="#FF6B7280" FontSize="13" VerticalAlignment="Top"
                               Visibility="{Binding NoTaken, Converter={StaticResource BoolToVis}}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasTaken, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding TakenRequests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF20242C" CornerRadius="8" Margin="0,0,0,10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDone}" Value="True"><Setter Property="Opacity" Value="0.6"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Border Width="4" HorizontalAlignment="Left" Background="{Binding StatusBrush}" CornerRadius="8,0,0,8"/>
                                            <StackPanel Margin="14,12,14,12">
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                                                        <Border Background="{Binding StatusBrush}" CornerRadius="4" Padding="6,1" Margin="0,0,4,0">
                                                            <TextBlock Text="{Binding StatusLabel}" Foreground="White" FontSize="10"/></Border>
                                                        <Border Background="{Binding PriorityBrush}" CornerRadius="4" Padding="6,1"
                                                                Visibility="{Binding ShowPriority, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="{Binding PriorityLabel}" Foreground="White" FontSize="10"/></Border>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding LocationLabel, StringFormat='📍 {0}'}" Foreground="#FF9AA4B2" FontSize="11"/>
                                                        <TextBlock Text="{Binding ClaimInfo}" Foreground="#FF6FA8CF" FontSize="11"
                                                                   Visibility="{Binding HasClaim, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </DockPanel>
                                                <TextBlock Text="ITEMS DEMANDÉS" Style="{StaticResource Label}" Margin="0,10,0,4"/>
                                                <ItemsControl ItemsSource="{Binding Items}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#FF2A3038" CornerRadius="6" Margin="0,0,6,6" Padding="6,3">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Image Source="{Binding Icon}" Width="22" Height="22" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding QtyText}" Foreground="#FF7FA8D9" FontSize="12" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Border Background="#FF15181E" CornerRadius="6" Margin="0,8,0,0" Padding="10">
                                                    <StackPanel>
                                                        <TextBlock Text="🏭 CRAFTS À FAIRE" Style="{StaticResource Label}" Margin="0,0,0,5"
                                                                   Visibility="{Binding HasCrafts, Converter={StaticResource BoolToVis}}"/>
                                                        <ItemsControl ItemsSource="{Binding Crafts}"
                                                                      Visibility="{Binding HasCrafts, Converter={StaticResource BoolToVis}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#FF20242C" CornerRadius="6" Margin="0,0,0,4" Padding="6,4">
                                                                        <DockPanel>
                                                                            <Border DockPanel.Dock="Right" Background="#FF2A3340" CornerRadius="4" Padding="6,1" VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding BuildingText}" Foreground="#FFB8C4D0" FontSize="10"/></Border>
                                                                            <TextBlock DockPanel.Dock="Right" Text="{Binding QtyText}" Foreground="#FFE6B45A" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="6,0,6,0"/>
                                                                            <Grid Width="24" Height="24" DockPanel.Dock="Left" Margin="0,0,8,0">
                                                                                <Border Background="#FF12151B" CornerRadius="4"/>
                                                                                <TextBlock Text="{Binding Initial}" Foreground="#FF9AA4B2" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                <Image Source="{Binding Icon}" Width="22" Height="22"/>
                                                                            </Grid>
                                                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                                                        </DockPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <TextBlock Text="⛏ RÉCOLTES À FAIRE (ressources brutes)" Style="{StaticResource Label}" Margin="0,8,0,5"
                                                                   Visibility="{Binding HasHarvests, Converter={StaticResource BoolToVis}}"/>
                                                        <ItemsControl ItemsSource="{Binding Harvests}"
                                                                      Visibility="{Binding HasHarvests, Converter={StaticResource BoolToVis}}">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#FF20242C" CornerRadius="6" Margin="0,0,6,4" Padding="6,4">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Image Source="{Binding Icon}" Width="22" Height="22" Margin="0,0,6,0"/>
                                                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding QtyText}" Foreground="#FF6FCF8E" FontWeight="Bold" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <Border Background="#FF20242C" CornerRadius="6" Margin="0,8,0,0" Padding="8,5">
                                                            <TextBlock Text="{Binding VehiclesText, StringFormat='🚚 {0}'}" Foreground="#FFB8C4D0" FontSize="12"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="{Binding Note}" Foreground="#FFB8C4D0" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                                                           Visibility="{Binding HasNote, Converter={StaticResource BoolToVis}}"/>
                                                <DockPanel Margin="0,8,0,0">
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                        <Button Content="{Binding ClaimButtonText}" Background="{Binding ClaimButtonBrush}" Style="{StaticResource FlatButton}"
                                                                Padding="12,5" Margin="0,0,4,0" FontSize="11" Click="OnClaimResupply"
                                                                Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}"/>
                                                        <Button Content="✓ Livré" Background="#FF2F6B43" Style="{StaticResource FlatButton}" Padding="12,5" Margin="0,0,4,0"
                                                                FontSize="11" Click="OnDoneResupply" Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}"/>
                                                        <Button Content="Rouvrir" Background="#FF333A45" Style="{StaticResource FlatButton}" Padding="12,5" Margin="0,0,4,0"
                                                                FontSize="11" Click="OnReopenResupply" Visibility="{Binding IsDone, Converter={StaticResource BoolToVis}}"/>
                                                        <Button Content="×" Background="#FF3A3030" Style="{StaticResource FlatButton}" Padding="9,5" FontSize="11"
                                                                Click="OnDeleteResupply" Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding CreatedInfo}" Foreground="#FF6B7280" FontSize="10" VerticalAlignment="Center"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
              </Grid>
            </Grid>
        </Grid>

        <!-- ====================== PORTE DE CONNEXION (au lancement) ====================== -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Background="#FF0E1014"
                Visibility="{Binding Friends.NeedsLogin, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
                <TextBlock Text="FoxholeLogiHub" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Gestion logistique pour Foxhole" Foreground="#FF9AA4B2" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                <Border Background="#FF1B1E24" CornerRadius="12" Padding="28,26" Margin="0,30,0,0"
                        BorderBrush="#FF2A2F38" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Connecte-toi avec Steam pour accéder à toutes les fonctionnalités : amis, régiment, stockpiles et ravitaillement."
                                   Foreground="#FFB8C4D0" FontSize="13" TextWrapping="Wrap" TextAlignment="Center"/>
                        <Button Content="🎮  Se connecter avec Steam" HorizontalAlignment="Center" Margin="0,20,0,0"
                                Style="{StaticResource FlatButton}" Background="#FF2A6E8F" Padding="22,11" FontSize="15"
                                Click="OnSteamLoginClick"/>
                        <TextBlock Text="{Binding Friends.Status}" Foreground="#FF9AA4B2" FontSize="11"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,16,0,0"/>
                    </StackPanel>
                </Border>
                <TextBlock Text="La connexion ouvre ton navigateur (OpenID Steam) — aucun mot de passe n'est partagé avec l'app."
                           Foreground="#FF6B7280" FontSize="10" TextWrapping="Wrap" TextAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

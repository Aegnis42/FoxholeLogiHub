<Window x:Class="FoxholeLogiHub.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FoxholeLogiHub" Height="720" Width="980"
        Background="{StaticResource B.Bg}" Foreground="{StaticResource B.Text}"
        FontFamily="{StaticResource F.Ui}"
        WindowStyle="SingleBorderWindow">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" ResizeBorderThickness="6" CornerRadius="0"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <!-- Contre-échelle des marqueurs/labels de la carte (partagée : mise à jour par le
             code-behind à chaque zoom → tous les éléments gardent une taille écran lisible). -->
        <ScaleTransform x:Key="MapMarkerScale" ScaleX="1" ScaleY="1"/>
        <ScaleTransform x:Key="MapLabelScale" ScaleX="1" ScaleY="1"/>
    </Window.Resources>

    <Border x:Name="WindowRoot" Background="{StaticResource B.Bg}">
      <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ====================== BARRE DE TITRE ====================== -->
        <Border Grid.Row="0" Background="{StaticResource B.BgDeep}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="12,0,0,0">
                    <Image Source="pack://application:,,,/Assets/logo.png" Width="18" Height="18"
                           RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>
                    <TextBlock Text="FoxholeLogiHub" FontSize="12.5" FontWeight="SemiBold"
                               Foreground="{StaticResource B.TextDim}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock Text="{Binding AppVersion}" FontSize="10.5" Foreground="{StaticResource B.TextMuted}"
                               VerticalAlignment="Center" Margin="8,1,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="OnCaptionMinimize"/>
                    <Button Style="{StaticResource CaptionButton}" Content="&#xE922;" Click="OnCaptionMaximize"/>
                    <Button Style="{StaticResource CaptionClose}" Content="&#xE8BB;" Click="OnCaptionClose"/>
                </StackPanel>
                <Border/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource B.BgDeep}" Padding="12,10,12,12" BorderBrush="{StaticResource B.Border}" BorderThickness="0,1,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <Button Click="OnNavDashboard">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDashboardActive}" Value="True">
                                        <Setter Property="Tag" Value="Active"/>
                                        <Setter Property="Background" Value="#FF151D2B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊  Dashboard" VerticalAlignment="Center"/>
                            <Border Background="#FFD23B41" CornerRadius="9" Padding="6,1" Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding Stockpiles.HasCritical, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding Stockpiles.CriticalCount}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Button>
                    <Button Content="🗺  Carte" Click="OnNavMap">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMapActive}" Value="True">
                                        <Setter Property="Tag" Value="Active"/>
                                        <Setter Property="Background" Value="#FF151D2B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="🧮  Calculatrice" Click="OnNavCalculator">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCalculatorActive}" Value="True">
                                        <Setter Property="Tag" Value="Active"/>
                                        <Setter Property="Background" Value="#FF151D2B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="⚙  Paramètres" Click="OnNavSettings">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                        <Setter Property="Tag" Value="Active"/>
                                        <Setter Property="Background" Value="#FF151D2B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="👤  Profil" Click="OnNavProfile">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProfileActive}" Value="True">
                                        <Setter Property="Tag" Value="Active"/>
                                        <Setter Property="Background" Value="#FF151D2B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="🫂  Amis" Click="OnNavFriends">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFriendsActive}" Value="True">
                                        <Setter Property="Tag" Value="Active"/>
                                        <Setter Property="Background" Value="#FF151D2B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="🛡  Régiment" Click="OnNavRegiment">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRegimentActive}" Value="True">
                                        <Setter Property="Tag" Value="Active"/>
                                        <Setter Property="Background" Value="#FF151D2B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="📦  Stockpiles" Click="OnNavStockpiles">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStockpilesActive}" Value="True">
                                        <Setter Property="Tag" Value="Active"/>
                                        <Setter Property="Background" Value="#FF151D2B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Click="OnNavResupply">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsResupplyActive}" Value="True">
                                        <Setter Property="Tag" Value="Active"/>
                                        <Setter Property="Background" Value="#FF151D2B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚚  Ravitaillement" VerticalAlignment="Center"/>
                            <Border Background="#FF2D63D8" CornerRadius="9" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding Resupply.HasOpen, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding Resupply.OpenCount}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Button>
                    <Button Click="OnNavTaken">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTakenActive}" Value="True">
                                        <Setter Property="Tag" Value="Active"/>
                                        <Setter Property="Background" Value="#FF151D2B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛠  Prises en charge" VerticalAlignment="Center"/>
                            <Border Background="#FF2F6B43" CornerRadius="9" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding Resupply.HasTaken, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding Resupply.TakenActiveCount}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Mise à jour prête + version (Velopack) -->
                <Button DockPanel.Dock="Bottom" Content="{Binding UpdateLabel}" Style="{StaticResource FlatButton}"
                        Background="#FF1F8A4C" Padding="8,6" Margin="0,0,0,8" Click="OnApplyUpdate"
                        Visibility="{Binding UpdateReady, Converter={StaticResource BoolToVis}}"
                        ToolTip="La nouvelle version est téléchargée — redémarre pour l'appliquer"/>
                <Button DockPanel.Dock="Bottom" Content="🗖 Overlay en jeu (F9)" Style="{StaticResource FlatButton}"
                        Background="#FF1A222E" Padding="8,5" Margin="0,0,0,8" Click="OnToggleOverlay"
                        ToolTip="Petite fenêtre toujours visible : alertes, MPF, recherche — par-dessus le jeu en mode fenêtré sans bordure. F9 pour basculer."/>
                <TextBlock DockPanel.Dock="Bottom" Text="{Binding AppVersion}" Foreground="#FF5E6B7E"
                           FontSize="10.5" Margin="4,0,0,6"/>

                <!-- Présence en bas -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,0,0,2">
                    <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FF5E6B7E"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Friends.Connected}" Value="True">
                                        <Setter Property="Fill" Value="#FF4CC26A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding Friends.Status}" FontSize="10" Foreground="#FF94A1B2"
                               TextWrapping="Wrap" Width="130"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Contenu -->
        <Grid Grid.Column="1" Margin="20">

            <!-- ====================== TABLEAU DE BORD ====================== -->
            <Grid Visibility="{Binding IsDashboardActive, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Tableau de bord" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Stockpiles.WarBanner}" Foreground="#FF6CA6F2" FontSize="12" Margin="0,4,0,0"
                               Visibility="{Binding Stockpiles.HasWar, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding Stockpiles.AlertsSummary}" Foreground="#FF94A1B2" FontSize="13" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Non connecté -->
                <TextBlock Grid.Row="1" Text="Connecte-toi avec Steam (onglet Amis) pour voir tes alertes."
                           Foreground="#FF5E6B7E" FontSize="14"
                           Visibility="{Binding Stockpiles.ShowAuthNeeded, Converter={StaticResource BoolToVis}}"/>

                <!-- Alertes -->
                <Grid Grid.Row="1" Visibility="{Binding Stockpiles.Authed, Converter={StaticResource BoolToVis}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                      <StackPanel>
                        <!-- Stockpiles menacés (contrôle des villes via l'API War) -->
                        <StackPanel Margin="0,0,0,8" Visibility="{Binding Stockpiles.HasThreats, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="🚨 STOCKPILES MENACÉS" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding Stockpiles.ThreatenedStockpiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF2A1B1B" BorderBrush="#FFD23B41" BorderThickness="1"
                                                CornerRadius="8" Margin="0,0,0,6" Padding="12,8">
                                            <DockPanel>
                                                <Border DockPanel.Dock="Right" Background="{Binding ThreatBrush}" CornerRadius="4"
                                                        Padding="8,2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ThreatLabel}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding LocationLabel}" Foreground="#FF94A1B2" FontSize="11"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <TextBlock Text="Aucune alerte. Définis des seuils bas/critique sur tes items (onglet Stockpiles) pour les voir apparaître ici."
                                   Foreground="#FF5E6B7E" FontSize="13" TextWrapping="Wrap"
                                   Visibility="{Binding Stockpiles.NoAlerts, Converter={StaticResource BoolToVis}}"/>
                        <ItemsControl ItemsSource="{Binding Stockpiles.AlertsView}">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,14,0,6">
                                                <TextBlock Text="📦" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="#FFE9EDF3"
                                                           VerticalAlignment="Center"/>
                                                <Border Background="#FF202A38" CornerRadius="9" Padding="7,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ItemCount}" Foreground="#FF94A1B2" FontSize="11"/>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF131A24" CornerRadius="8" Margin="0,0,0,6">
                                        <Grid>
                                            <Border Width="4" HorizontalAlignment="Left" Background="{Binding SeverityBrush}"
                                                    CornerRadius="8,0,0,8"/>
                                            <DockPanel Margin="14,8,12,8">
                                                <Grid Width="36" Height="36" DockPanel.Dock="Left" Margin="0,0,12,0" VerticalAlignment="Center">
                                                    <Border Background="#FF10161F" CornerRadius="6"/>
                                                    <TextBlock Text="{Binding Initial}" Foreground="#FF94A1B2" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <Image Source="{Binding Icon}" Width="34" Height="34"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Grid>
                                                <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding QuantityText}" FontWeight="Bold" FontSize="17"
                                                               Foreground="{Binding SeverityBrush}" TextAlignment="Right"/>
                                                    <TextBlock Text="{Binding ThresholdText}" Foreground="#FF5E6B7E" FontSize="10"
                                                               TextAlignment="Right"/>
                                                </StackPanel>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding SeverityBrush}" FontSize="11"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ====================== PROFIL ====================== -->
            <Grid Visibility="{Binding IsProfileActive, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Profil" FontSize="22" FontWeight="Bold" DockPanel.Dock="Left"/>
                    <Button Content="Rafraîchir" DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Style="{StaticResource FlatButton}" Click="OnRefreshClick"/>
                </DockPanel>

                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Width="96" Height="96" Margin="0,0,20,0">
                            <Ellipse Fill="{Binding FactionBrush}"/>
                            <Ellipse>
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding Avatar}" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Stroke="#33FFFFFF" StrokeThickness="2"/>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="PSEUDO" Style="{StaticResource Label}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="22" FontWeight="Bold" Foreground="White"
                                         Background="Transparent" BorderThickness="0" Padding="0"
                                         CaretBrush="White" MaxLength="40"/>
                                <Button Grid.Column="1" Content="Enregistrer" Style="{StaticResource FlatButton}"
                                        Margin="10,0,0,0" Click="OnSaveProfileClick"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Steam : " Foreground="#FF94A1B2" FontSize="12"/>
                                <TextBlock Text="{Binding SteamId}" FontSize="12"/>
                                <TextBlock Text="  ·  pseudo Steam : " Foreground="#FF94A1B2" FontSize="12"/>
                                <TextBlock Text="{Binding PersonaName}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="2" Background="{Binding FactionBrush}" CornerRadius="6"
                                Padding="14,10" VerticalAlignment="Center" Margin="20,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="FACTION" Foreground="#CCFFFFFF" FontSize="10"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Faction}" FontSize="16" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <UniformGrid Columns="3" Rows="1">
                            <StackPanel>
                                <TextBlock Text="DERNIER SERVEUR" Style="{StaticResource Label}"/>
                                <TextBlock Text="{Binding Server}" FontSize="15"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="LANGUE" Style="{StaticResource Label}"/>
                                <TextBlock Text="{Binding Language}" FontSize="15"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="GUERRES REJOINTES" Style="{StaticResource Label}"/>
                                <TextBlock Text="{Binding WarCount}" FontSize="15"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock Text="Loadouts sauvegardés" FontSize="16" FontWeight="SemiBold"
                                   DockPanel.Dock="Top" Margin="0,0,0,12"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Loadouts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF1F2937" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold"
                                                           Margin="0,0,0,8"/>
                                                <ItemsControl ItemsSource="{Binding Equipment}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <DockPanel Margin="0,1">
                                                                <TextBlock Text="{Binding Slot}" Width="80"
                                                                           Foreground="#FF6CA6F2" FontSize="12"/>
                                                                <TextBlock Text="{Binding CodeName}" FontSize="13"/>
                                                                <TextBlock Text="{Binding Quantity, StringFormat='×{0}'}"
                                                                           DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                                           Foreground="#FF94A1B2"/>
                                                            </DockPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <ItemsControl ItemsSource="{Binding Backpack}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <DockPanel Margin="0,1">
                                                                <TextBlock Text="sac" Width="80"
                                                                           Foreground="#FF8AA37A" FontSize="12"/>
                                                                <TextBlock Text="{Binding CodeName}" FontSize="13"/>
                                                                <TextBlock Text="{Binding Quantity, StringFormat='×{0}'}"
                                                                           DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                                           Foreground="#FF94A1B2"/>
                                                            </DockPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <TextBlock Grid.Row="4" Text="{Binding Status}" Foreground="#FF94A1B2" FontSize="12"/>
            </Grid>

            <!-- ====================== AMIS ====================== -->
            <Grid Visibility="{Binding IsFriendsActive, Converter={StaticResource BoolToVis}}">
              <Grid DataContext="{Binding Friends}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Amis" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>

                <!-- Mon code d'ami -->
                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <Grid>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Se déconnecter" VerticalAlignment="Top"
                                    HorizontalAlignment="Right" Style="{StaticResource FlatButton}"
                                    Background="#FF3A3030" Padding="10,5" Click="OnLogoutClick"/>
                            <StackPanel>
                                <TextBlock Text="MON CODE D'AMI" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding MyFriendCode, Mode=OneWay}" IsReadOnly="True"
                                         FontSize="26" FontWeight="Bold" Foreground="#FF6CA6F2"
                                         Background="Transparent" BorderThickness="0" Padding="0"
                                         FontFamily="Consolas"/>
                                <TextBlock Text="Partage ce code pour qu'on t'ajoute en ami."
                                           Foreground="#FF94A1B2" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>

                <!-- Ajouter un ami -->
                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="AJOUTER UN AMI PAR CODE" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding AddCodeInput, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="15" Padding="8" Background="#FF10161F" Foreground="White"
                                     BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"
                                     VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="Envoyer" Style="{StaticResource FlatButton}"
                                    Margin="10,0,0,0" Click="OnSendRequestClick" IsEnabled="{Binding Connected}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Demandes reçues -->
                <Border Grid.Row="3" Style="{StaticResource Card}"
                        Visibility="{Binding HasRequests, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Demandes reçues" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding Requests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF33384A" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" Width="40" Height="40" Margin="0,0,12,0">
                                                <Ellipse Fill="{Binding FactionBrush}"/>
                                                <TextBlock Text="{Binding Initial}" Foreground="White"
                                                           FontWeight="Bold" FontSize="16"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Ellipse>
                                                    <Ellipse.Fill>
                                                        <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                            </Grid>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Faction}" FontSize="11" Foreground="#FF94A1B2"/>
                                            </StackPanel>

                                            <Button Grid.Column="2" Content="Accepter" Style="{StaticResource FlatButton}"
                                                    Background="#FF2F6B43" Padding="12,6" Margin="0,0,8,0"
                                                    Click="OnAcceptRequestClick"/>
                                            <Button Grid.Column="3" Content="Refuser" Style="{StaticResource FlatButton}"
                                                    Background="#FF3A3030" Padding="12,6" Click="OnDeclineRequestClick"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Liste d'amis -->
                <Border Grid.Row="4" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Mes amis" FontSize="16" FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        <Grid DockPanel.Dock="Top">
                            <TextBlock Text="Aucun ami pour l'instant. Partage ton code ou ajoute un code ci-dessus."
                                       Foreground="#FF5E6B7E" FontSize="13"
                                       Visibility="{Binding HasNoFriends, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Friends}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF1F2937" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0" Width="40" Height="40" Margin="0,0,12,0">
                                                    <Ellipse Fill="{Binding FactionBrush}"/>
                                                    <TextBlock Text="{Binding Initial}" Foreground="White"
                                                               FontWeight="Bold" FontSize="16"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <Ellipse>
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <Ellipse Width="12" Height="12" HorizontalAlignment="Right"
                                                             VerticalAlignment="Bottom" Stroke="#FF1F2937"
                                                             StrokeThickness="2" Fill="{Binding StatusBrush}"/>
                                                </Grid>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Faction}" FontSize="11" Foreground="#FF94A1B2"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="12"
                                                           Foreground="{Binding StatusBrush}" VerticalAlignment="Center"
                                                           Margin="0,0,12,0"/>

                                                <Button Grid.Column="3" Content="Retirer" Style="{StaticResource FlatButton}"
                                                        Background="#FF3A3030" Padding="10,5" Click="OnRemoveFriendClick"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
              </Grid>
            </Grid>

            <!-- ====================== RÉGIMENT ====================== -->
            <Grid Visibility="{Binding IsRegimentActive, Converter={StaticResource BoolToVis}}">
              <Grid DataContext="{Binding Regiment}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Régiment" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="#FF94A1B2" FontSize="12" Margin="0,8,0,0"/>

                    <Grid>
                        <!-- État : connexion requise -->
                        <Border Style="{StaticResource Card}" VerticalAlignment="Top"
                                Visibility="{Binding ShowAuthNeeded, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Connecte-toi avec Steam (onglet Amis) pour créer ou gérer ton régiment."
                                       Foreground="#FF94A1B2" FontSize="13" TextWrapping="Wrap"/>
                        </Border>

                        <!-- État : pas de régiment -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding ShowNoRegiment, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Border Style="{StaticResource Card}"
                                        Visibility="{Binding HasInvites, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Invitations reçues" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding Invites}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF33384A" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                        <DockPanel>
                                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                                <Button Content="Accepter" Style="{StaticResource FlatButton}"
                                                                        Background="#FF2F6B43" Padding="12,6" Margin="0,0,8,0" Click="OnAcceptRegInvite"/>
                                                                <Button Content="Refuser" Style="{StaticResource FlatButton}"
                                                                        Background="#FF3A3030" Padding="12,6" Click="OnDeclineRegInvite"/>
                                                            </StackPanel>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding FromDisplayName, StringFormat='Invité par {0}'}"
                                                                           FontSize="11" Foreground="#FF94A1B2"/>
                                                            </StackPanel>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="CRÉER UN RÉGIMENT" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"
                                                 FontSize="15" Padding="8" Background="#FF10161F" Foreground="White"
                                                 BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"
                                                 ToolTip="Nom du régiment"/>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="Créer" Style="{StaticResource FlatButton}"
                                                    Background="#FF2D63D8" Padding="16,8" Margin="10,0,0,0" Click="OnCreateRegiment"/>
                                            <TextBox Text="{Binding NewTag, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="15" Padding="8" Background="#FF10161F" Foreground="White"
                                                     BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"
                                                     ToolTip="Tag court, ex. FOX"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="REJOINDRE PAR CODE" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="Rejoindre" Style="{StaticResource FlatButton}"
                                                    Padding="16,8" Margin="10,0,0,0" Click="OnJoinRegiment"/>
                                            <TextBox Text="{Binding JoinCode, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="15" Padding="8" Background="#FF10161F" Foreground="White"
                                                     BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"
                                                     VerticalContentAlignment="Center"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- État : membre d'un régiment -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding ShowRegiment, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <!-- En-tête -->
                                <Border Style="{StaticResource Card}">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Top" HorizontalAlignment="Right">
                                            <Button Content="Régénérer le code" Style="{StaticResource FlatButton}"
                                                    Background="#FF202A38" Padding="10,5" Margin="0,0,0,6" Click="OnRegenCode"
                                                    Visibility="{Binding CanInvite, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="🏁 Fin de guerre (reset)" Style="{StaticResource FlatButton}"
                                                    Background="#FF4A3A2A" Padding="10,5" Margin="0,0,0,6" Click="OnWarReset"
                                                    Visibility="{Binding IAmOwner, Converter={StaticResource BoolToVis}}"
                                                    ToolTip="Archive en JSON local puis supprime tous les stockpiles et demandes du régiment (nouvelle guerre)"/>
                                            <Button Content="Supprimer le régiment" Style="{StaticResource FlatButton}"
                                                    Background="#FF5A2A2A" Padding="10,5" Click="OnDeleteRegiment"
                                                    Visibility="{Binding IAmOwner, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="Quitter le régiment"
                                                    Background="#FF3A3030" Padding="10,5" Click="OnLeaveRegiment">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FlatButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IAmOwner}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock FontSize="22" FontWeight="Bold">
                                                <Run Text="{Binding Name, Mode=OneWay}"/>
                                                <Run Text="{Binding Tag, Mode=OneWay, StringFormat=' [{0}]'}" Foreground="#FF94A1B2"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Faction}" FontSize="12" Foreground="#FF6CA6F2" Margin="0,2,0,8"/>
                                            <TextBlock Text="CODE D'INVITATION" Style="{StaticResource Label}"/>
                                            <TextBox Text="{Binding InviteCode, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas"
                                                     FontSize="20" FontWeight="Bold" Foreground="#FF6CA6F2"
                                                     Background="Transparent" BorderThickness="0" Padding="0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- Webhook Discord (chef uniquement) -->
                                <Border Style="{StaticResource Card}"
                                        Visibility="{Binding IAmOwner, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="🔔 Webhook Discord" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock Foreground="#FF94A1B2" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,8"
                                                   Text="Les alertes du régiment (stock critique, stockpile menacé, demandes de ravitaillement créées/prises/livrées) seront postées dans ton salon Discord. Crée un webhook dans Discord : Paramètres du salon → Intégrations → Webhooks, puis colle son URL ici."/>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="Enregistrer" Style="{StaticResource FlatButton}"
                                                    Background="#FF2D63D8" Padding="14,6" Margin="8,0,0,0" Click="OnSaveWebhook"/>
                                            <TextBox Text="{Binding WebhookInput, UpdateSourceTrigger=PropertyChanged}" FontSize="13" Padding="7"
                                                     Background="#FF10161F" Foreground="White" BorderBrush="#FF232C3A" BorderThickness="1"
                                                     CaretBrush="White" ToolTip="https://discord.com/api/webhooks/…"/>
                                        </DockPanel>
                                        <DockPanel Margin="0,6,0,0">
                                            <Button DockPanel.Dock="Right" Content="Désactiver" Style="{StaticResource FlatButton}"
                                                    Background="#FF8E3438" Padding="10,6" Margin="8,0,0,0" Click="OnDisableWebhook"
                                                    ToolTip="Coupe le webhook et sa mention"/>
                                            <TextBlock DockPanel.Dock="Left" Text="Rôle à mentionner :" Foreground="#FF94A1B2" FontSize="12"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox Text="{Binding WebhookTagInput, UpdateSourceTrigger=PropertyChanged}" FontSize="13" Padding="7"
                                                     Background="#FF10161F" Foreground="White" BorderBrush="#FF232C3A" BorderThickness="1"
                                                     CaretBrush="White"
                                                     ToolTip="ID du rôle Discord (clic droit sur le rôle → Copier l'identifiant), ou @everyone / @here — pingué en tête de chaque alerte. Vide = aucune mention. Le rôle doit être mentionnable."/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding WebhookState}" Foreground="#FF6CA6F2" FontSize="12" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Membres -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Membres" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding Members}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF1F2937" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid Grid.Column="0" Width="38" Height="38" Margin="0,0,12,0">
                                                                <Ellipse Fill="{Binding FactionBrush}"/>
                                                                <TextBlock Text="{Binding Initial}" Foreground="White" FontWeight="Bold"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                <Ellipse><Ellipse.Fill><ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill"/></Ellipse.Fill></Ellipse>
                                                                <Ellipse Width="11" Height="11" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                                         Stroke="#FF1F2937" StrokeThickness="2" Fill="{Binding StatusBrush}"/>
                                                            </Grid>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding RoleBadge}" FontSize="11" Foreground="#FF94A1B2"/>
                                                            </StackPanel>
                                                            <ComboBox Grid.Column="2" Width="120" Margin="0,0,8,0" VerticalAlignment="Center"
                                                                      ItemsSource="{Binding Roles}" DisplayMemberPath="Name" SelectedValuePath="Id"
                                                                      SelectedValue="{Binding RoleId, Mode=OneWay}" SelectionChanged="OnMemberRoleChanged"
                                                                      Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                            <Button Grid.Column="3" Content="Exclure" Style="{StaticResource FlatButton}"
                                                                    Background="#FF3A3030" Padding="10,5" Click="OnKickMember"
                                                                    Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Inviter des amis -->
                                <Border Style="{StaticResource Card}" Visibility="{Binding CanInvite, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Inviter des amis" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding Friends}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF1F2937" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                                        <DockPanel>
                                                            <Button DockPanel.Dock="Right" Content="Inviter" Style="{StaticResource FlatButton}"
                                                                    Background="#FF2D63D8" Padding="12,5" Click="OnInviteFriendToReg"/>
                                                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="13"/>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Rôles & permissions -->
                                <Border Style="{StaticResource Card}" Visibility="{Binding CanManageRoles, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Rôles &amp; permissions" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding Roles}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF1F2937" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                                    <Button Content="Enregistrer" Style="{StaticResource FlatButton}"
                                                                            Background="#FF2F6B43" Padding="10,5" Margin="0,0,6,0" Click="OnSaveRole"/>
                                                                    <Button Content="Suppr." Style="{StaticResource FlatButton}"
                                                                            Background="#FF3A3030" Padding="10,5" Click="OnDeleteRole"
                                                                            Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}"/>
                                                                </StackPanel>
                                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" FontWeight="SemiBold"
                                                                         FontSize="14" Background="Transparent" Foreground="White" BorderThickness="0"
                                                                         CaretBrush="White" VerticalAlignment="Center"/>
                                                            </DockPanel>
                                                            <WrapPanel Margin="0,8,0,0">
                                                                <CheckBox Content="Membres" IsChecked="{Binding PMembers}"/>
                                                                <CheckBox Content="Rôles" IsChecked="{Binding PRoles}"/>
                                                                <CheckBox Content="Inviter" IsChecked="{Binding PInvite}"/>
                                                                <CheckBox Content="Régiment" IsChecked="{Binding PRegiment}"/>
                                                                <CheckBox Content="Alliances" IsChecked="{Binding PAlliances}"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <DockPanel Margin="0,4,0,0">
                                            <Button DockPanel.Dock="Right" Content="+ Rôle" Style="{StaticResource FlatButton}"
                                                    Padding="14,6" Margin="10,0,0,0" Click="OnCreateRole"/>
                                            <TextBox Text="{Binding NewRoleName, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="13" Padding="6" Background="#FF10161F" Foreground="White"
                                                     BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"
                                                     VerticalContentAlignment="Center" ToolTip="Nom du nouveau rôle"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Alliances -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Alliances" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding Alliances}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF1F2937" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                        <DockPanel>
                                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                                <Button Content="Accepter" Style="{StaticResource FlatButton}"
                                                                        Background="#FF2F6B43" Padding="10,5" Margin="0,0,6,0" Click="OnAcceptAlliance"
                                                                        Visibility="{Binding IsIncomingRequest, Converter={StaticResource BoolToVis}}"/>
                                                                <Button Content="Refuser" Style="{StaticResource FlatButton}"
                                                                        Background="#FF3A3030" Padding="10,5" Click="OnDeclineAlliance"
                                                                        Visibility="{Binding IsIncomingRequest, Converter={StaticResource BoolToVis}}"/>
                                                                <Button Content="Rompre" Style="{StaticResource FlatButton}"
                                                                        Background="#FF3A3030" Padding="10,5" Click="OnRemoveAlliance"
                                                                        Visibility="{Binding IsAccepted, Converter={StaticResource BoolToVis}}"/>
                                                            </StackPanel>
                                                            <Border DockPanel.Dock="Left" Width="6" CornerRadius="3" Margin="0,0,10,0"
                                                                    Background="{Binding FactionBrush}"/>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding StateText}" FontSize="11" Foreground="#FF94A1B2"/>
                                                            </StackPanel>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <DockPanel Margin="0,4,0,0" Visibility="{Binding CanManageAlliances, Converter={StaticResource BoolToVis}}">
                                            <Button DockPanel.Dock="Right" Content="Proposer" Style="{StaticResource FlatButton}"
                                                    Background="#FF2D63D8" Padding="14,6" Margin="10,0,0,0" Click="OnProposeAlliance"/>
                                            <TextBox Text="{Binding AllianceCode, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="13" Padding="6" Background="#FF10161F" Foreground="White"
                                                     BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"
                                                     VerticalContentAlignment="Center" ToolTip="Code d'invitation du régiment à allier"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </DockPanel>
              </Grid>
            </Grid>

            <!-- ====================== STOCKPILES ====================== -->
            <Grid Visibility="{Binding IsStockpilesActive, Converter={StaticResource BoolToVis}}">
              <Grid DataContext="{Binding Stockpiles}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Stockpiles" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="#FF94A1B2" FontSize="12" Margin="0,8,0,0"/>
                    <Grid>
                        <Border Style="{StaticResource Card}" VerticalAlignment="Top"
                                Visibility="{Binding ShowAuthNeeded, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Connecte-toi avec Steam (onglet Amis) pour gérer les stockpiles."
                                       Foreground="#FF94A1B2" FontSize="13" TextWrapping="Wrap"/>
                        </Border>
                        <Border Style="{StaticResource Card}" VerticalAlignment="Top"
                                Visibility="{Binding ShowNoRegiment, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Rejoins ou crée un régiment (onglet Régiment) : les stockpiles appartiennent au régiment."
                                       Foreground="#FF94A1B2" FontSize="13" TextWrapping="Wrap"/>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding ShowStockpiles, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <!-- Formulaire création / édition -->
                                <Border Style="{StaticResource Card}" Visibility="{Binding ShowForm, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SubmitLabel}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="NOM" Style="{StaticResource Label}"/>
                                                <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14" Padding="7" Background="#FF10161F" Foreground="White"
                                                         BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="TYPE" Style="{StaticResource Label}"/>
                                                <ComboBox ItemsSource="{Binding Types}" DisplayMemberPath="Label" SelectedValuePath="Value"
                                                          SelectedValue="{Binding FormType}" Padding="6" FontSize="14"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="HEXAGONE" Style="{StaticResource Label}"/>
                                                <ComboBox IsEditable="True" Text="{Binding FormHex, UpdateSourceTrigger=PropertyChanged}"
                                                          ItemsSource="{Binding Hexes}" Padding="6" FontSize="14"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="LIEU (optionnel)" Style="{StaticResource Label}"/>
                                                <TextBox Text="{Binding FormTown, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14" Padding="7" Background="#FF10161F" Foreground="White"
                                                         BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"/>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,0,0,8"
                                                    Visibility="{Binding FormUsesCode, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="CODE (mot de passe du Port/Dépôt)" Style="{StaticResource Label}"/>
                                            <TextBox Text="{Binding FormCode, UpdateSourceTrigger=PropertyChanged}" MaxLength="8" Width="160"
                                                     HorizontalAlignment="Left" FontFamily="Consolas" FontSize="15" Padding="7"
                                                     Background="#FF10161F" Foreground="White" BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"/>
                                        </StackPanel>
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                <Button Content="Annuler" Style="{StaticResource FlatButton}" Background="#FF3A3030"
                                                        Padding="12,7" Margin="0,0,8,0" Click="OnCancelStockpileEdit"
                                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                                                <Button Content="{Binding SubmitLabel}" Style="{StaticResource FlatButton}"
                                                        Background="#FF2D63D8" Padding="16,7" Click="OnSubmitStockpile"/>
                                            </StackPanel>
                                            <CheckBox Content="Public (visible par les alliés)" IsChecked="{Binding FormIsPublic}" VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Recherche globale d'items -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="🔍 Trouver un item" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="✕" Style="{StaticResource FlatButton}" Background="#FF202A38"
                                                    Padding="10,6" Margin="6,0,0,0" Click="OnStockpileSearchClear"
                                                    Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVis}}"/>
                                            <Button DockPanel.Dock="Right" Content="Chercher" Style="{StaticResource FlatButton}" Background="#FF2D63D8"
                                                    Padding="14,6" Margin="8,0,0,0" Click="OnStockpileSearch"/>
                                            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="7"
                                                     Background="#FF10161F" Foreground="White" BorderBrush="#FF232C3A" BorderThickness="1"
                                                     CaretBrush="White" KeyDown="OnStockpileSearchKey"
                                                     ToolTip="Nom ou code d'item (ex. 7.92, Bmats, bandage…) — cherche dans tous les stockpiles visibles"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding SearchStatus}" Foreground="#FF94A1B2" FontSize="12" Margin="0,6,0,0"/>
                                        <ItemsControl ItemsSource="{Binding SearchResults}" Margin="0,6,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel Margin="0,2">
                                                        <Image Source="{Binding Icon}" Width="22" Height="22" Margin="0,0,8,0"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}"/>
                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding QtyText}" Foreground="#FF53C272"
                                                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13"/>
                                                            <TextBlock Text="{Binding WhereText}" Foreground="#FF94A1B2" FontSize="11" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Liste -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Stockpiles (les miens + ceux des alliés)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Aucun stockpile pour l'instant." Foreground="#FF5E6B7E" FontSize="13"
                                                   Visibility="{Binding HasNoStockpiles, Converter={StaticResource BoolToVis}}"/>
                                        <ItemsControl ItemsSource="{Binding Stockpiles}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF1F2937" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <Border DockPanel.Dock="Right" Background="{Binding VisibilityBrush}" CornerRadius="4"
                                                                        Padding="8,3" VerticalAlignment="Top">
                                                                    <TextBlock Text="{Binding VisibilityLabel}" Foreground="White" FontSize="11"/>
                                                                </Border>
                                                                <Border DockPanel.Dock="Right" Background="{Binding ThreatBrush}" CornerRadius="4"
                                                                        Padding="8,3" Margin="0,0,6,0" VerticalAlignment="Top"
                                                                        Visibility="{Binding IsThreatened, Converter={StaticResource BoolToVis}}">
                                                                    <TextBlock Text="{Binding ThreatLabel}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <Button DockPanel.Dock="Right" Content="Items" Style="{StaticResource FlatButton}"
                                                                        Background="#FF202A38" Padding="10,4" Margin="0,0,8,0" VerticalAlignment="Top"
                                                                        Click="OnSelectStockpile"/>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold"/>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding TypeLabel}" Foreground="#FF6CA6F2" FontSize="12"/>
                                                                        <TextBlock Text="  ·  " Foreground="#FF5E6B7E" FontSize="12"/>
                                                                        <TextBlock Text="{Binding LocationLabel}" Foreground="#FF94A1B2" FontSize="12"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </DockPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                                                        Visibility="{Binding HasCode, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="Code : " Foreground="#FF94A1B2" FontSize="12" VerticalAlignment="Center"/>
                                                                <TextBox Text="{Binding Code, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas"
                                                                         FontSize="14" FontWeight="Bold" Foreground="#FF6CA6F2" Background="Transparent"
                                                                         BorderThickness="0" Padding="0"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding RegimentName, StringFormat='Régiment allié : {0}'}"
                                                                       Foreground="#FF8AA37A" FontSize="11" Margin="0,4,0,0"
                                                                       Visibility="{Binding ShowForeignRegiment, Converter={StaticResource BoolToVis}}"/>

                                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                                        Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}">
                                                                <Button Content="Modifier" Style="{StaticResource FlatButton}" Background="#FF202A38"
                                                                        Padding="10,4" Margin="0,0,6,0" Click="OnEditStockpile"/>
                                                                <Button Content="Supprimer" Style="{StaticResource FlatButton}" Background="#FF3A3030"
                                                                        Padding="10,4" Click="OnDeleteStockpile"/>
                                                            </StackPanel>

                                                            <StackPanel Margin="0,8,0,0"
                                                                        Visibility="{Binding ShowShareSection, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="Partager avec un allié :" Foreground="#FF94A1B2" FontSize="11" Margin="0,0,0,4"/>
                                                                <ItemsControl ItemsSource="{Binding ShareTargets}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Content="{Binding ButtonText}" Background="{Binding ButtonBrush}"
                                                                                    Style="{StaticResource FlatButton}" Padding="10,4" Margin="0,0,6,6"
                                                                                    Click="OnToggleShare"/>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Détail : contenu (items) du stockpile sélectionné -->
                                <Border Style="{StaticResource Card}"
                                        Visibility="{Binding IsStockpileSelected, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
                                            <Button DockPanel.Dock="Right" Content="Fermer" Style="{StaticResource FlatButton}"
                                                    Background="#FF202A38" Padding="10,4" Click="OnCloseDetail"/>
                                            <TextBlock Text="{Binding SelectedName, StringFormat='Contenu — {0}'}"
                                                       FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </DockPanel>

                                        <Border Background="#FF1A2A47" CornerRadius="6" Padding="10" Margin="0,0,0,10"
                                                Visibility="{Binding SelectedCanManage, Converter={StaticResource BoolToVis}}">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="📷 Importer (capture)" Style="{StaticResource FlatButton}"
                                                        Background="#FF2D63D8" Padding="14,6" Click="OnImportCapture"/>
                                                <TextBlock VerticalAlignment="Center" Foreground="#FFB6C2D1" FontSize="11" TextWrapping="Wrap"
                                                           Text="Remplissage auto (FIR) : ouvre le stockpile en VUE-CARTE en jeu, puis clique (4 s pour basculer) — ou appuie sur F8 directement en jeu. Compatible mods d'icônes."/>
                                            </DockPanel>
                                        </Border>

                                        <StackPanel Margin="0,0,0,12"
                                                    Visibility="{Binding SelectedCanManage, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="AJOUTER / MODIFIER (item · quantité · seuil bas · seuil critique)"
                                                       Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="Définir" Style="{StaticResource FlatButton}"
                                                        Background="#FF2D63D8" Padding="14,6" Margin="6,0,0,0" Click="OnSetItem"/>
                                                <TextBox DockPanel.Dock="Right" Width="70" Margin="6,0,0,0"
                                                         Text="{Binding NewItemCritical, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14" Padding="6" Background="#FF10161F" Foreground="White"
                                                         BorderBrush="#FFD23B41" BorderThickness="1" CaretBrush="White"
                                                         VerticalContentAlignment="Center" ToolTip="Seuil critique (🔴 ≤)"/>
                                                <TextBox DockPanel.Dock="Right" Width="70" Margin="6,0,0,0"
                                                         Text="{Binding NewItemLow, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14" Padding="6" Background="#FF10161F" Foreground="White"
                                                         BorderBrush="#FFE8A33D" BorderThickness="1" CaretBrush="White"
                                                         VerticalContentAlignment="Center" ToolTip="Seuil bas (🟠 ≤)"/>
                                                <TextBox DockPanel.Dock="Right" Width="80" Margin="6,0,0,0"
                                                         Text="{Binding NewItemQuantity, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14" Padding="6" Background="#FF10161F" Foreground="White"
                                                         BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"
                                                         VerticalContentAlignment="Center" ToolTip="Quantité (0 = retirer)"/>
                                                <ComboBox IsEditable="True" ItemsSource="{Binding ItemNames}" FontSize="14" Padding="6"
                                                          Text="{Binding NewItemName, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DockPanel>

                                            <!-- Templates d'objectifs : applique/sauve un jeu de seuils du régiment -->
                                            <DockPanel Margin="0,8,0,0">
                                                <TextBlock DockPanel.Dock="Left" Text="🎯 TEMPLATE :" Style="{StaticResource Label}"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <Button DockPanel.Dock="Right" Content="💾 Sauver les seuils" Style="{StaticResource FlatButton}"
                                                        Background="#FF1F8A4C" Padding="10,5" Margin="6,0,0,0" Click="OnSaveTemplate"
                                                        ToolTip="Enregistre les seuils définis sur ce stockpile comme template du régiment"/>
                                                <TextBox DockPanel.Dock="Right" Width="150" Margin="10,0,0,0"
                                                         Text="{Binding TemplateName, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="12.5" Padding="5" Background="#FF10161F" Foreground="White"
                                                         BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"
                                                         VerticalContentAlignment="Center" ToolTip="Nom du template à créer (ex. « Dépôt de front »)"/>
                                                <Button DockPanel.Dock="Right" Content="🗑" Style="{StaticResource FlatButton}"
                                                        Background="#FF3A3030" Padding="8,5" Margin="6,0,0,0" Click="OnDeleteTemplate"
                                                        ToolTip="Supprimer le template sélectionné"/>
                                                <Button DockPanel.Dock="Right" Content="Appliquer" Style="{StaticResource FlatButton}"
                                                        Background="#FF2D63D8" Padding="10,5" Margin="6,0,0,0" Click="OnApplyTemplate"
                                                        ToolTip="Applique les seuils du template à ce stockpile (items absents créés à 0)"/>
                                                <ComboBox ItemsSource="{Binding Templates}" SelectedItem="{Binding SelectedTemplate}"
                                                          FontSize="12.5" Padding="5" VerticalAlignment="Center">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock>
                                                                <Run Text="{Binding Name, Mode=OneWay}"/><Run Text="{Binding ItemCount, Mode=OneWay, StringFormat=' ({0} seuils)'}" Foreground="#FF94A1B2"/>
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </DockPanel>

                                            <!-- Transfert d'un item vers un autre stockpile (bouton ⇄ des cartes) -->
                                            <Border Background="#FF1A2A47" CornerRadius="6" Padding="9" Margin="0,8,0,0"
                                                    Visibility="{Binding TransferActive, Converter={StaticResource BoolToVis}}">
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Left" Text="{Binding TransferTitle}" FontWeight="SemiBold"
                                                               Foreground="White" FontSize="12.5" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <Button DockPanel.Dock="Right" Content="Annuler" Style="{StaticResource FlatButton}"
                                                            Background="#FF202A38" Padding="9,4" Margin="6,0,0,0" Click="OnCancelTransfer"/>
                                                    <Button DockPanel.Dock="Right" Content="⇄ Transférer" Style="{StaticResource FlatButton}"
                                                            Background="#FF1F8A4C" Padding="10,4" Margin="8,0,0,0" Click="OnConfirmTransfer"/>
                                                    <TextBox DockPanel.Dock="Left" Width="80" Margin="0,0,8,0"
                                                             Text="{Binding TransferQty, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="13" Padding="5" Background="#FF10161F" Foreground="White"
                                                             BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"
                                                             VerticalContentAlignment="Center" ToolTip="Quantité à transférer"/>
                                                    <ComboBox ItemsSource="{Binding TransferTargets}" SelectedItem="{Binding TransferTarget}"
                                                              DisplayMemberPath="Name" FontSize="12.5" Padding="5" VerticalAlignment="Center"
                                                              ToolTip="Stockpile de destination"/>
                                                </DockPanel>
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Text="Aucun item. Ajoute-en ci-dessus ou via 📷 Importer." Foreground="#FF5E6B7E" FontSize="13"
                                                   Visibility="{Binding HasNoItems, Converter={StaticResource BoolToVis}}"/>
                                        <ItemsControl ItemsSource="{Binding ItemsView}">
                                            <ItemsControl.GroupStyle>
                                                <GroupStyle>
                                                    <GroupStyle.HeaderTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FF94A1B2"
                                                                       FontSize="12" Margin="2,10,0,6"/>
                                                        </DataTemplate>
                                                    </GroupStyle.HeaderTemplate>
                                                    <GroupStyle.Panel>
                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                    </GroupStyle.Panel>
                                                </GroupStyle>
                                            </ItemsControl.GroupStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="158" Background="#FF1F2937" CornerRadius="8" Margin="0,0,8,8">
                                                        <Grid>
                                                            <Border Width="4" HorizontalAlignment="Left" Background="{Binding StatusBrush}"
                                                                    CornerRadius="8,0,0,8"/>
                                                            <StackPanel Margin="12,8,8,8">
                                                                <DockPanel>
                                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                                                                        <Button Content="ⓘ" Style="{StaticResource FlatButton}" Background="#FF232C3A"
                                                                                Padding="6,1" Margin="0,0,4,0" Click="OnItemDetails" FontSize="11"
                                                                                ToolTip="Détails / recette de craft"/>
                                                                        <Button Content="⇄" Style="{StaticResource FlatButton}" Background="#FF2D63D8"
                                                                                Padding="6,1" Margin="0,0,4,0" Click="OnTransferItem" FontSize="11"
                                                                                ToolTip="Transférer vers un autre stockpile"
                                                                                Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                                        <Button Content="✎" Style="{StaticResource FlatButton}" Background="#FF202A38"
                                                                                Padding="6,1" Margin="0,0,4,0" Click="OnEditItem" FontSize="11"
                                                                                Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                                        <Button Content="×" Style="{StaticResource FlatButton}" Background="#FF3A3030"
                                                                                Padding="7,1" Click="OnRemoveItem" FontSize="11"
                                                                                Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                                    </StackPanel>
                                                                    <Grid Width="40" Height="40" HorizontalAlignment="Left">
                                                                        <Border Background="#FF10161F" CornerRadius="6"/>
                                                                        <TextBlock Text="{Binding Initial}" Foreground="#FF94A1B2" FontWeight="Bold"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        <Image Source="{Binding Icon}" Width="38" Height="38" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                    </Grid>
                                                                </DockPanel>
                                                                <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#FFE9EDF3"
                                                                           TextWrapping="Wrap" Height="30" Margin="0,6,0,2"/>
                                                                <DockPanel>
                                                                    <Border DockPanel.Dock="Right" Background="{Binding StatusBrush}" CornerRadius="4"
                                                                            Padding="6,1" VerticalAlignment="Center"
                                                                            Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
                                                                        <TextBlock Text="{Binding StatusLabel}" Foreground="White" FontSize="10"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding QuantityText}" FontWeight="Bold" FontSize="18"
                                                                               Foreground="#FFE9EDF3"/>
                                                                </DockPanel>
                                                                <TextBlock Text="{Binding TrendText}" Foreground="{Binding TrendBrush}" FontSize="10.5"
                                                                           ToolTip="{Binding TrendTooltip}" Margin="0,3,0,0"
                                                                           Visibility="{Binding HasTrend, Converter={StaticResource BoolToVis}}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Journal des transferts récents du régiment -->
                                        <Expander Margin="0,10,0,0" Foreground="#FF94A1B2"
                                                  Visibility="{Binding HasTransfers, Converter={StaticResource BoolToVis}}">
                                            <Expander.Header>
                                                <TextBlock Text="⇄ Journal des transferts récents" FontSize="12" Foreground="#FF94A1B2"/>
                                            </Expander.Header>
                                            <ItemsControl ItemsSource="{Binding Transfers}" Margin="16,6,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Foreground="#FFB6C2D1" FontSize="11.5" Margin="0,1"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </DockPanel>

                <!-- ===== Fiche détaillée d'un item (gestion poussée : catégorie, caisse, recette) ===== -->
                <Border Background="#CC0A0C10" Visibility="{Binding HasItemDetail, Converter={StaticResource BoolToVis}}">
                    <Border Width="430" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Background="#FF1B1F27" CornerRadius="12" BorderBrush="#FF232C3A" BorderThickness="1"
                            DataContext="{Binding ItemDetail}">
                        <DockPanel>
                            <!-- En-tête -->
                            <Border DockPanel.Dock="Top" Background="#FF222834" CornerRadius="12,12,0,0">
                                <DockPanel Margin="16,14">
                                    <Button DockPanel.Dock="Right" Content="✕" Style="{StaticResource FlatButton}"
                                            Background="#FF202A38" Padding="9,3" VerticalAlignment="Top" Click="OnCloseItemDetail"/>
                                    <Grid Width="48" Height="48" DockPanel.Dock="Left" Margin="0,0,12,0" VerticalAlignment="Top">
                                        <Border Background="#FF12151B" CornerRadius="8"/>
                                        <TextBlock Text="{Binding Initial}" Foreground="#FF94A1B2" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Image Source="{Binding Icon}" Width="44" Height="44" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Category}" Foreground="#FF94A1B2" FontSize="12" Margin="0,1,0,0"/>
                                        <TextBlock Text="{Binding CaliberLabel}" Foreground="#FF6CA6F2" FontSize="11"
                                                   Visibility="{Binding HasCaliber, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <!-- Corps -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="16,12,16,16">
                                    <DockPanel Margin="0,0,0,12">
                                        <TextBlock Text="📦 Caisse" Foreground="#FF94A1B2" FontSize="12" Width="90" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding CrateText}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                    </DockPanel>

                                    <TextBlock Text="{Binding RecipeHeader}" Style="{StaticResource Label}" Margin="0,0,0,6"
                                               Visibility="{Binding HasRecipe, Converter={StaticResource BoolToVis}}"/>
                                    <ItemsControl ItemsSource="{Binding Recipes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FF131A24" CornerRadius="8" Margin="0,0,0,8" Padding="10,8">
                                                    <StackPanel>
                                                        <DockPanel Margin="0,0,0,6">
                                                            <TextBlock DockPanel.Dock="Right" Text="{Binding OutputText}" Foreground="#FF6FCF8E"
                                                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                                                       Visibility="{Binding HasOutput, Converter={StaticResource BoolToVis}}"/>
                                                            <TextBlock Text="{Binding Header}" Foreground="#FFB6C2D1" FontSize="13" FontWeight="SemiBold"/>
                                                        </DockPanel>
                                                        <ItemsControl ItemsSource="{Binding Ingredients}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#FF141B24" CornerRadius="6" Margin="0,0,0,4" Padding="6,4">
                                                                        <DockPanel>
                                                                            <TextBlock DockPanel.Dock="Right" Text="{Binding QtyText}" Foreground="#FFE6B45A"
                                                                                       FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                                                            <Grid Width="26" Height="26" DockPanel.Dock="Left" Margin="0,0,8,0">
                                                                                <Border Background="#FF12151B" CornerRadius="5"/>
                                                                                <TextBlock Text="{Binding Initial}" Foreground="#FF94A1B2" FontSize="10"
                                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                <Image Source="{Binding Icon}" Width="24" Height="24"/>
                                                                            </Grid>
                                                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                                                        </DockPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <TextBlock Text="{Binding MetaText}" Foreground="#FF94A1B2" FontSize="11" Margin="0,2,0,0"
                                                                   Visibility="{Binding HasMeta, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="ℹ La MPF produit en lot (3/9/...) avec une remise de matériaux à volume."
                                               Foreground="#FF5E6B7E" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"
                                               Visibility="{Binding HasMpf, Converter={StaticResource BoolToVis}}"/>

                                    <TextBlock Text="{Binding NoRecipeText}" Foreground="#FF5E6B7E" FontSize="12" TextWrapping="Wrap"
                                               Visibility="{Binding NoRecipe, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Border>
              </Grid>
            </Grid>

            <!-- ====================== RAVITAILLEMENT ====================== -->
            <Grid Visibility="{Binding IsResupplyActive, Converter={StaticResource BoolToVis}}">
              <Grid DataContext="{Binding Resupply}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Ravitaillement" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Summary}" Foreground="#FF94A1B2" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="Connecte-toi avec Steam (onglet Amis)." Foreground="#FF5E6B7E" FontSize="14"
                           Visibility="{Binding ShowAuthNeeded, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Grid.Row="1" Text="Rejoins un régiment pour gérer le ravitaillement." Foreground="#FF5E6B7E" FontSize="14"
                           Visibility="{Binding ShowNoRegiment, Converter={StaticResource BoolToVis}}"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding ShowResupply, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <!-- Nouvelle demande (multi-items) -->
                        <Border Background="#FF10161F" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="NOUVELLE DEMANDE (nom · hexagone · coordonnées · priorité · visibilité, puis ajoute des items)"
                                           Style="{StaticResource Label}" Margin="0,0,0,8"/>
                                <TextBox Margin="0,0,0,8" Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="7"
                                         Background="#FF10161F" Foreground="White" BorderBrush="#FF232C3A" BorderThickness="1"
                                         CaretBrush="White" VerticalContentAlignment="Center" ToolTip="Nom de la demande"/>
                                <DockPanel Margin="0,0,0,8">
                                    <ComboBox DockPanel.Dock="Right" Width="155" Margin="6,0,0,0" SelectedValuePath="Value"
                                              DisplayMemberPath="Label" SelectedValue="{Binding NewVisibility}"
                                              ItemsSource="{Binding Visibilities}" FontSize="14" Padding="6" ToolTip="Visibilité (qui voit la demande)"/>
                                    <ComboBox DockPanel.Dock="Right" Width="110" Margin="6,0,0,0" SelectedValuePath="Value"
                                              DisplayMemberPath="Label" SelectedValue="{Binding NewPriority}"
                                              ItemsSource="{Binding Priorities}" FontSize="14" Padding="6" ToolTip="Priorité"/>
                                    <TextBox DockPanel.Dock="Right" Width="120" Margin="6,0,0,0"
                                             Text="{Binding NewCoords, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" Padding="6" Background="#FF10161F" Foreground="White"
                                             BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"
                                             VerticalContentAlignment="Center" ToolTip="Coordonnées (ex. E5, 123x456)"/>
                                    <ComboBox IsEditable="True" ItemsSource="{Binding Hexes}"
                                              Text="{Binding NewHex, UpdateSourceTrigger=PropertyChanged}"
                                              FontSize="14" Padding="6" ToolTip="Hexagone"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Content="+ Ajouter l'item" Style="{StaticResource FlatButton}"
                                            Background="#FF202A38" Padding="12,6" Margin="6,0,0,0" Click="OnAddDraftItem"/>
                                    <TextBox DockPanel.Dock="Right" Width="80" Margin="6,0,0,0"
                                             Text="{Binding DraftItemQuantity, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" Padding="6" Background="#FF10161F" Foreground="White"
                                             BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"
                                             VerticalContentAlignment="Center" ToolTip="Quantité"/>
                                    <ComboBox IsEditable="True" ItemsSource="{Binding ItemNames}" FontSize="14" Padding="6"
                                              Text="{Binding DraftItemName, UpdateSourceTrigger=PropertyChanged}" ToolTip="Item à ajouter"/>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding DraftItems}" Margin="0,0,0,8"
                                              Visibility="{Binding HasDraft, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FF2A3038" CornerRadius="6" Margin="0,0,6,6" Padding="6,3">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="{Binding Icon}" Width="22" Height="22" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding QtyText}" Foreground="#FF6CA6F2" FontSize="12" FontWeight="Bold"
                                                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                    <Button Content="×" Style="{StaticResource FlatButton}" Background="#FF3A3030"
                                                            Padding="6,0" Margin="8,0,0,0" FontSize="11" Click="OnRemoveDraftItem"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Créer la demande" Style="{StaticResource FlatButton}"
                                            Background="#FF2D63D8" Padding="14,6" Margin="6,0,0,0" Click="OnCreateResupply"/>
                                    <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" FontSize="13" Padding="6"
                                             Background="#FF10161F" Foreground="White" BorderBrush="#FF232C3A" BorderThickness="1"
                                             CaretBrush="White" VerticalContentAlignment="Center" ToolTip="Note (optionnel)"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Manques détectés -->
                        <StackPanel Margin="0,0,0,14" Visibility="{Binding HasNeeds, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="MANQUES DÉTECTÉS (items sous seuil dans tes stockpiles)"
                                       Style="{StaticResource Label}" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding Needs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF131A24" CornerRadius="6" Margin="0,0,0,5" Padding="8,5">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="+ Brouillon" Style="{StaticResource FlatButton}"
                                                        Background="#FF2D63D8" Padding="10,3" Margin="6,0,0,0" FontSize="11"
                                                        Click="OnCreateFromNeed" VerticalAlignment="Center"
                                                        ToolTip="Ajouter ce manque à la demande en cours de création"/>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding DeficitText}" Foreground="{Binding DeficitBrush}"
                                                           FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                <Grid Width="30" Height="30" DockPanel.Dock="Left" Margin="0,0,10,0">
                                                    <Border Background="#FF12151B" CornerRadius="5"/>
                                                    <TextBlock Text="{Binding Initial}" Foreground="#FF94A1B2" FontSize="11"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <Image Source="{Binding Icon}" Width="28" Height="28"/>
                                                </Grid>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13"/>
                                                    <TextBlock Text="{Binding LocationLabel}" Foreground="#FF94A1B2" FontSize="10"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- File MPF du régiment -->
                        <Border Style="{StaticResource Card}" DataContext="{Binding DataContext.Stockpiles, RelativeSource={RelativeSource AncestorType=Window}}">
                            <StackPanel>
                                <TextBlock Text="🏭 File MPF du régiment" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Note tes commandes MPF (item, caisses, temps restant lu en jeu) : tout le régiment voit les comptes à rebours, et Discord prévient quand c'est prêt."
                                           Foreground="#FF94A1B2" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="➕ Noter" Style="{StaticResource FlatButton}"
                                            Background="#FF2D63D8" Padding="12,6" Margin="6,0,0,0" Click="OnCreateMpf"/>
                                    <TextBox DockPanel.Dock="Right" Width="46" Margin="2,0,0,0" ToolTip="Minutes restantes"
                                             Text="{Binding MpfMinutes, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="13" Padding="5" Background="#FF10161F" Foreground="White"
                                             BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White" VerticalContentAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right" Text="h" Foreground="#FF5E6B7E" VerticalAlignment="Center" Margin="3,0"/>
                                    <TextBox DockPanel.Dock="Right" Width="40" Margin="6,0,0,0" ToolTip="Heures restantes"
                                             Text="{Binding MpfHours, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="13" Padding="5" Background="#FF10161F" Foreground="White"
                                             BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White" VerticalContentAlignment="Center"/>
                                    <ComboBox DockPanel.Dock="Right" Width="150" Margin="6,0,0,0" IsEditable="True" ToolTip="Hexagone du MPF (optionnel)"
                                              ItemsSource="{Binding Hexes}" Text="{Binding MpfHex, UpdateSourceTrigger=PropertyChanged}"
                                              FontSize="12.5" Padding="5"/>
                                    <TextBox DockPanel.Dock="Right" Width="60" Margin="6,0,0,0" ToolTip="Nombre de caisses"
                                             Text="{Binding MpfCrates, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="13" Padding="5" Background="#FF10161F" Foreground="White"
                                             BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White" VerticalContentAlignment="Center"/>
                                    <ComboBox IsEditable="True" ItemsSource="{Binding ItemNames}" FontSize="12.5" Padding="5"
                                              Text="{Binding MpfItemName, UpdateSourceTrigger=PropertyChanged}" ToolTip="Item produit"/>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding MpfOrders}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FF1A222E" CornerRadius="6" Padding="8,6" Margin="0,0,0,4">
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right" Content="✔ Récupéré" Style="{StaticResource FlatButton}"
                                                            Background="#FF1F8A4C" Padding="9,3" FontSize="11" Click="OnCollectMpf"
                                                            Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding RemainingText}" Foreground="{Binding RemainingBrush}"
                                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="{Binding Icon}" Width="22" Height="22" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock VerticalAlignment="Center" FontSize="13" Foreground="White">
                                                            <Run Text="{Binding Name, Mode=OneWay}"/>
                                                            <Run Text="{Binding CratesText, Mode=OneWay}" Foreground="#FF53C272"/>
                                                            <Run Text="{Binding ByText, Mode=OneWay}" Foreground="#FF5E6B7E" FontSize="11"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Demandes ouvertes -->
                        <TextBlock Text="DEMANDES OUVERTES" Style="{StaticResource Label}" Margin="0,0,0,6"
                                   Visibility="{Binding HasOpen, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="Aucune demande ouverte. Crée-en une ci-dessus, ou ajoute des manques au brouillon (+ Brouillon)."
                                   Foreground="#FF5E6B7E" FontSize="13"
                                   Visibility="{Binding NoOpen, Converter={StaticResource BoolToVis}}"/>
                        <ItemsControl ItemsSource="{Binding OpenRequests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF131A24" CornerRadius="8" Margin="0,0,0,8">
                                        <Grid>
                                            <Border Width="4" HorizontalAlignment="Left" Background="{Binding StatusBrush}" CornerRadius="8,0,0,8"/>
                                            <StackPanel Margin="14,10,12,10">
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                                                        <Border Background="{Binding VisibilityBrush}" CornerRadius="4" Padding="6,1" Margin="0,0,4,0">
                                                            <TextBlock Text="{Binding VisibilityLabel}" Foreground="White" FontSize="10"/></Border>
                                                        <Border Background="{Binding StatusBrush}" CornerRadius="4" Padding="6,1" Margin="0,0,4,0">
                                                            <TextBlock Text="{Binding StatusLabel}" Foreground="White" FontSize="10"/></Border>
                                                        <Border Background="{Binding PriorityBrush}" CornerRadius="4" Padding="6,1"
                                                                Visibility="{Binding ShowPriority, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="{Binding PriorityLabel}" Foreground="White" FontSize="10"/></Border>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding LocationLabel, StringFormat='📍 {0}'}" Foreground="#FF94A1B2" FontSize="11"/>
                                                        <TextBlock Text="{Binding OwnerLabel}" Foreground="#FF6FA8CF" FontSize="10"
                                                                   Visibility="{Binding ShowOwner, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </DockPanel>
                                                <ItemsControl ItemsSource="{Binding Items}" Margin="0,8,0,0">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#FF2A3038" CornerRadius="6" Margin="0,0,6,6" Padding="6,3">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Image Source="{Binding Icon}" Width="22" Height="22" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding QtyText}" Foreground="#FF6CA6F2" FontSize="12" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="{Binding Note}" Foreground="#FFB6C2D1" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                                           Visibility="{Binding HasNote, Converter={StaticResource BoolToVis}}"/>
                                                <DockPanel Margin="0,8,0,0">
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                        <Button Content="{Binding ClaimButtonText}" Background="{Binding ClaimButtonBrush}"
                                                                Style="{StaticResource FlatButton}" Padding="12,5" Margin="0,0,4,0" FontSize="11" Click="OnClaimResupply"
                                                                Visibility="{Binding CanClaim, Converter={StaticResource BoolToVis}}"/>
                                                        <Button Content="✓ Livré" Background="#FF2F6B43" Style="{StaticResource FlatButton}"
                                                                Padding="12,5" Margin="0,0,4,0" FontSize="11" Click="OnDoneResupply"
                                                                Visibility="{Binding CanComplete, Converter={StaticResource BoolToVis}}"/>
                                                        <Button Content="×" Background="#FF3A3030" Style="{StaticResource FlatButton}"
                                                                Padding="9,5" FontSize="11" Click="OnDeleteResupply"
                                                                Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding CreatedInfo}" Foreground="#FF5E6B7E" FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <Button Content="🔒" Style="{StaticResource FlatButton}" Background="#FF202A38" Padding="6,2" Margin="0,0,3,0" FontSize="10"
                                                                Click="OnVisRegiment" ToolTip="Rendre privé (régiment)"
                                                                Visibility="{Binding CanSetRegiment, Converter={StaticResource BoolToVis}}"/>
                                                        <Button Content="🤝" Style="{StaticResource FlatButton}" Background="#FF2A4A5A" Padding="6,2" Margin="0,0,3,0" FontSize="10"
                                                                Click="OnVisAlliance" ToolTip="Partager à l'alliance"
                                                                Visibility="{Binding CanSetAlliance, Converter={StaticResource BoolToVis}}"/>
                                                        <Button Content="🌍" Style="{StaticResource FlatButton}" Background="#FF4A5A2A" Padding="6,2" FontSize="10"
                                                                Click="OnVisPublic" ToolTip="Rendre public (tous les utilisateurs)"
                                                                Visibility="{Binding CanSetPublic, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
              </Grid>
            </Grid>

            <!-- ====================== PRISES EN CHARGE ====================== -->
            <Grid Visibility="{Binding IsTakenActive, Converter={StaticResource BoolToVis}}">
              <Grid DataContext="{Binding Resupply}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Prises en charge" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Demandes prises par le régiment, avec le plan de production (crafts, récoltes, véhicules)."
                               Foreground="#FF94A1B2" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>
                <TextBlock Grid.Row="1" Text="Connecte-toi avec Steam (onglet Amis)." Foreground="#FF5E6B7E" FontSize="14"
                           Visibility="{Binding ShowAuthNeeded, Converter={StaticResource BoolToVis}}"/>
                <Grid Grid.Row="1" Visibility="{Binding ShowResupply, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Aucune demande prise en charge. Va dans « Ravitaillement » et clique « Prendre en charge »."
                               Foreground="#FF5E6B7E" FontSize="13" VerticalAlignment="Top"
                               Visibility="{Binding NoTaken, Converter={StaticResource BoolToVis}}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasTaken, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding TakenRequests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF131A24" CornerRadius="8" Margin="0,0,0,10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDone}" Value="True"><Setter Property="Opacity" Value="0.6"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Border Width="4" HorizontalAlignment="Left" Background="{Binding StatusBrush}" CornerRadius="8,0,0,8"/>
                                            <StackPanel Margin="14,12,14,12">
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                                                        <Border Background="{Binding VisibilityBrush}" CornerRadius="4" Padding="6,1" Margin="0,0,4,0">
                                                            <TextBlock Text="{Binding VisibilityLabel}" Foreground="White" FontSize="10"/></Border>
                                                        <Border Background="{Binding StatusBrush}" CornerRadius="4" Padding="6,1" Margin="0,0,4,0">
                                                            <TextBlock Text="{Binding StatusLabel}" Foreground="White" FontSize="10"/></Border>
                                                        <Border Background="{Binding PriorityBrush}" CornerRadius="4" Padding="6,1"
                                                                Visibility="{Binding ShowPriority, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="{Binding PriorityLabel}" Foreground="White" FontSize="10"/></Border>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding LocationLabel, StringFormat='📍 {0}'}" Foreground="#FF94A1B2" FontSize="11"/>
                                                        <TextBlock Text="{Binding OwnerLabel}" Foreground="#FF6FA8CF" FontSize="11"
                                                                   Visibility="{Binding ShowOwner, Converter={StaticResource BoolToVis}}"/>
                                                        <TextBlock Text="{Binding ClaimInfo}" Foreground="#FF6FA8CF" FontSize="11"
                                                                   Visibility="{Binding HasClaim, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </DockPanel>
                                                <TextBlock Text="ITEMS DEMANDÉS" Style="{StaticResource Label}" Margin="0,10,0,4"/>
                                                <ItemsControl ItemsSource="{Binding Items}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#FF2A3038" CornerRadius="6" Margin="0,0,6,6" Padding="6,3">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Image Source="{Binding Icon}" Width="22" Height="22" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding QtyText}" Foreground="#FF6CA6F2" FontSize="12" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Border Background="#FF10161F" CornerRadius="6" Margin="0,8,0,0" Padding="10">
                                                    <StackPanel>
                                                        <TextBlock Text="🏭 CRAFTS À FAIRE" Style="{StaticResource Label}" Margin="0,0,0,5"
                                                                   Visibility="{Binding HasCrafts, Converter={StaticResource BoolToVis}}"/>
                                                        <ItemsControl ItemsSource="{Binding Crafts}"
                                                                      Visibility="{Binding HasCrafts, Converter={StaticResource BoolToVis}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#FF131A24" CornerRadius="6" Margin="0,0,0,4" Padding="6,4">
                                                                        <DockPanel>
                                                                            <Border DockPanel.Dock="Right" Background="#FF232C3A" CornerRadius="4" Padding="6,1" VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding BuildingText}" Foreground="#FFB6C2D1" FontSize="10"/></Border>
                                                                            <TextBlock DockPanel.Dock="Right" Text="{Binding QtyText}" Foreground="#FFE6B45A" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="6,0,6,0"/>
                                                                            <Grid Width="24" Height="24" DockPanel.Dock="Left" Margin="0,0,8,0">
                                                                                <Border Background="#FF12151B" CornerRadius="4"/>
                                                                                <TextBlock Text="{Binding Initial}" Foreground="#FF94A1B2" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                <Image Source="{Binding Icon}" Width="22" Height="22"/>
                                                                            </Grid>
                                                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                                                        </DockPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <TextBlock Text="⛏ RÉCOLTES À FAIRE (ressources brutes)" Style="{StaticResource Label}" Margin="0,8,0,5"
                                                                   Visibility="{Binding HasHarvests, Converter={StaticResource BoolToVis}}"/>
                                                        <ItemsControl ItemsSource="{Binding Harvests}"
                                                                      Visibility="{Binding HasHarvests, Converter={StaticResource BoolToVis}}">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#FF131A24" CornerRadius="6" Margin="0,0,6,4" Padding="6,4">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Image Source="{Binding Icon}" Width="22" Height="22" Margin="0,0,6,0"/>
                                                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding QtyText}" Foreground="#FF6FCF8E" FontWeight="Bold" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <Border Background="#FF131A24" CornerRadius="6" Margin="0,8,0,0" Padding="8,5">
                                                            <DockPanel>
                                                                <Button DockPanel.Dock="Right" Content="🗺 Où produire ?" Style="{StaticResource FlatButton}"
                                                                        Background="#FF2D63D8" FontSize="11" Padding="9,4" Click="OnResupplyProduceMap"
                                                                        ToolTip="Voir sur la carte les usines, raffineries et champs de ressources utiles à ce plan"/>
                                                                <TextBlock Text="{Binding VehiclesText, StringFormat='🚚 {0}'}" Foreground="#FFB6C2D1"
                                                                           FontSize="12" VerticalAlignment="Center"/>
                                                            </DockPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="{Binding Note}" Foreground="#FFB6C2D1" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                                                           Visibility="{Binding HasNote, Converter={StaticResource BoolToVis}}"/>
                                                <DockPanel Margin="0,8,0,0">
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                        <Button Content="{Binding ClaimButtonText}" Background="{Binding ClaimButtonBrush}" Style="{StaticResource FlatButton}"
                                                                Padding="12,5" Margin="0,0,4,0" FontSize="11" Click="OnClaimResupply"
                                                                Visibility="{Binding CanClaim, Converter={StaticResource BoolToVis}}"/>
                                                        <Button Content="✓ Livré" Background="#FF2F6B43" Style="{StaticResource FlatButton}" Padding="12,5" Margin="0,0,4,0"
                                                                FontSize="11" Click="OnDoneResupply" Visibility="{Binding CanComplete, Converter={StaticResource BoolToVis}}"/>
                                                        <Button Content="Rouvrir" Background="#FF202A38" Style="{StaticResource FlatButton}" Padding="12,5" Margin="0,0,4,0"
                                                                FontSize="11" Click="OnReopenResupply" Visibility="{Binding CanReopen, Converter={StaticResource BoolToVis}}"/>
                                                        <Button Content="×" Background="#FF3A3030" Style="{StaticResource FlatButton}" Padding="9,5" FontSize="11"
                                                                Click="OnDeleteResupply" Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding CreatedInfo}" Foreground="#FF5E6B7E" FontSize="10" VerticalAlignment="Center"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
              </Grid>
            </Grid>
            <!-- ====================== CARTE DU MONDE ====================== -->
            <Grid Visibility="{Binding IsMapActive, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <Button DockPanel.Dock="Right" Content="🌍 Vue monde" Style="{StaticResource FlatButton}"
                            Background="#FF202A38" Padding="12,6" VerticalAlignment="Top" Click="OnMapReset"
                            ToolTip="Dézoomer pour voir le monde entier"/>
                    <CheckBox DockPanel.Dock="Right" Content="⛏ Ressources" IsChecked="{Binding Map.ShowResources}"
                              VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#FFB6C2D1"
                              ToolTip="Afficher les champs et mines de ressources (ferraille, composants, soufre, charbon, pétrole…)"/>
                    <ToggleButton DockPanel.Dock="Right" Content="📏 Mesurer" IsChecked="{Binding Map.MeasureActive}"
                                  Padding="10,5" Margin="0,0,12,0" VerticalAlignment="Top"
                                  Background="#FF202A38" Foreground="White" BorderThickness="0"
                                  ToolTip="Mesurer une distance : clique un point A puis un point B (re-clique pour recommencer)"/>
                    <StackPanel>
                        <TextBlock Text="Carte du monde" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Map.Status}" Foreground="#FF94A1B2" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </DockPanel>

                <TextBlock Grid.Row="1" Text="Connecte-toi avec Steam pour voir la carte." Foreground="#FF5E6B7E" FontSize="14"
                           Visibility="{Binding Map.ShowAuthNeeded, Converter={StaticResource BoolToVis}}"/>

                <Grid Grid.Row="1" Visibility="{Binding Map.Authed, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="265"/>
                    </Grid.ColumnDefinitions>

                    <!-- Zone carte : molette = zoom, glisser = déplacer, clic = sélectionner -->
                    <Border Grid.Column="0" x:Name="MapViewport" Background="#FF0E1116" CornerRadius="8"
                            ClipToBounds="True" Cursor="Hand"
                            MouseWheel="OnMapWheel"
                            PreviewMouseLeftButtonDown="OnMapMouseDown"
                            PreviewMouseMove="OnMapMouseMove"
                            PreviewMouseLeftButtonUp="OnMapMouseUp"
                            MouseRightButtonUp="OnMapRightClick">
                      <!-- Canvas intermédiaire : slot de mesure infini → pas de LayoutClip sur la grille
                           transformée (sinon WPF rogne le monde à la taille du viewport AVANT le zoom). -->
                      <Canvas>
                        <Grid x:Name="MapRoot" Width="{Binding Map.CanvasWidth}" Height="{Binding Map.CanvasHeight}"
                              HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent">
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="MapScale" ScaleX="0.45" ScaleY="0.45"/>
                                    <TranslateTransform x:Name="MapTranslate"/>
                                </TransformGroup>
                            </Grid.RenderTransform>

                            <!-- Couche 1 : hexagones -->
                            <ItemsControl ItemsSource="{Binding Map.Hexes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding W}" Height="{Binding H}">
                                            <!-- Fond de carte officiel (terrain), découpé en hexagone -->
                                            <Image Source="{Binding Tile}" Stretch="Fill" Clip="{Binding HexClip}"
                                                   IsHitTestVisible="False" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <!-- Sous-régions : zone d'influence de chaque ville (Voronoï) -->
                                            <ItemsControl ItemsSource="{Binding Cells}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Polygon Points="{Binding Points}" Fill="{Binding Fill}"
                                                                 Stroke="#500E1116"
                                                                 StrokeThickness="{Binding DataContext.Map.CellStrokeThickness, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                 ToolTip="{Binding Tooltip}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- Bord de l'hexagone (rempli seulement s'il n'a pas de sous-régions) -->
                                            <Polygon Points="{Binding Points}" Fill="{Binding Fill}"
                                                     Stroke="{Binding Stroke}" StrokeThickness="{Binding StrokeThickness}"/>
                                            <TextBlock Text="{Binding Display}" Foreground="#B8FFFFFF" FontSize="11"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       TextAlignment="Center" TextWrapping="Wrap" MaxWidth="92"
                                                       IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5"
                                                       RenderTransform="{StaticResource MapLabelScale}">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect BlurRadius="3" ShadowDepth="0" Color="#FF000000"/>
                                                </TextBlock.Effect>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Couche 2 : villes -->
                            <ItemsControl ItemsSource="{Binding Map.Towns}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Ancre 0×0 au point monde : la contre-échelle garde le point à taille écran constante -->
                                        <Canvas Width="0" Height="0" RenderTransform="{StaticResource MapMarkerScale}">
                                            <Ellipse Canvas.Left="-4" Canvas.Top="-4" Width="8" Height="8" Fill="{Binding Fill}"
                                                     Stroke="#FF10131A" StrokeThickness="1" ToolTip="{Binding Tooltip}"/>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Couche 3 : structures (hexagone sélectionné, ou tous en zoom profond) -->
                            <ItemsControl ItemsSource="{Binding Map.MapStructures}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas Width="0" Height="0" RenderTransform="{StaticResource MapMarkerScale}">
                                            <!-- Anneau doré : structure utile au plan de production (« Où produire ? ») -->
                                            <Ellipse Canvas.Left="-13" Canvas.Top="-13" Width="26" Height="26"
                                                     Stroke="#FFE7B73C" StrokeThickness="2" Fill="#2EE7B73C"
                                                     IsHitTestVisible="False"
                                                     Visibility="{Binding IsHighlighted, Converter={StaticResource BoolToVis}}"/>
                                            <Grid Canvas.Left="-9" Canvas.Top="-9" ToolTip="{Binding Tooltip}">
                                                <Ellipse Width="18" Height="18" Fill="#D912151B"
                                                         Stroke="{Binding TeamBrush}" StrokeThickness="1.5"/>
                                                <TextBlock Text="{Binding Glyph}" FontSize="9"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Couche 4 : noms des villes (hexagone sélectionné, ou tous en zoom profond) -->
                            <ItemsControl ItemsSource="{Binding Map.TownLabels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas Width="0" Height="0" RenderTransform="{StaticResource MapMarkerScale}">
                                            <TextBlock Canvas.Left="7" Canvas.Top="-7" Text="{Binding Name}"
                                                       Foreground="White" FontSize="9.5"
                                                       FontWeight="SemiBold" IsHitTestVisible="False">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect BlurRadius="3" ShadowDepth="0" Color="#FF000000"/>
                                                </TextBlock.Effect>
                                            </TextBlock>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Couche 5 : stockpiles -->
                            <ItemsControl ItemsSource="{Binding Map.Pins}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas Width="0" Height="0" RenderTransform="{StaticResource MapMarkerScale}">
                                            <!-- Icône (selon type) posée au-dessus du point d'ancrage -->
                                            <Grid Canvas.Left="-9" Canvas.Top="-22" ToolTip="{Binding Tooltip}">
                                                <Ellipse Width="20" Height="20" Margin="-2"
                                                         Fill="#66C03A3A" Stroke="#FFD23B41" StrokeThickness="1.5"
                                                         Visibility="{Binding IsThreatened, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Text="{Binding Glyph}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Couche 6 : mesure de distance -->
                            <Canvas Visibility="{Binding Map.MeasureVisible, Converter={StaticResource BoolToVis}}"
                                    IsHitTestVisible="False">
                                <Line X1="{Binding Map.MeasureX1}" Y1="{Binding Map.MeasureY1}"
                                      X2="{Binding Map.MeasureX2}" Y2="{Binding Map.MeasureY2}"
                                      Stroke="#FFE7B73C" StrokeDashArray="4 3"
                                      StrokeThickness="{Binding Map.CellStrokeThickness}"/>
                                <Canvas Width="0" Height="0" RenderTransform="{StaticResource MapMarkerScale}"
                                        Canvas.Left="{Binding Map.MeasureLabelX}" Canvas.Top="{Binding Map.MeasureLabelY}">
                                    <Border Canvas.Left="8" Canvas.Top="-26" Background="#E5141B26" CornerRadius="4"
                                            Padding="7,3" BorderBrush="#FFE7B73C" BorderThickness="1">
                                        <TextBlock Text="{Binding Map.MeasureLabel}" Foreground="White"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </Canvas>
                            </Canvas>
                        </Grid>
                      </Canvas>
                    </Border>

                    <!-- Bandeau du mode « choisir l'emplacement » -->
                    <Border Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0"
                            Background="#F01E2530" CornerRadius="6" Padding="14,8" BorderBrush="#FF4A90D9" BorderThickness="1"
                            Visibility="{Binding Map.PickActive, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Map.PickBanner}" Foreground="White" FontSize="12.5"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Content="Annuler" Style="{StaticResource FlatButton}" Background="#FF202A38"
                                    Padding="10,4" Margin="12,0,0,0" Click="OnMapPickCancel"/>
                        </StackPanel>
                    </Border>

                    <!-- Légende -->
                    <Border Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10"
                            Background="#D915181E" CornerRadius="6" Padding="10,6" IsHitTestVisible="False">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#FF245C8A" VerticalAlignment="Center"/>
                            <TextBlock Text="Wardens" Foreground="#FFB6C2D1" FontSize="11" Margin="4,0,10,0"/>
                            <Ellipse Width="10" Height="10" Fill="#FF516C42" VerticalAlignment="Center"/>
                            <TextBlock Text="Colonials" Foreground="#FFB6C2D1" FontSize="11" Margin="4,0,10,0"/>
                            <Ellipse Width="10" Height="10" Fill="#FF6E2222" VerticalAlignment="Center"/>
                            <TextBlock Text="Rasée" Foreground="#FFB6C2D1" FontSize="11" Margin="4,0,10,0"/>
                            <TextBlock Text="📦 Stockpile" Foreground="#FFB6C2D1" FontSize="11"/>
                            <TextBlock Text="· molette = zoom · glisser = déplacer · clic = région" Foreground="#FF5E6B7E" FontSize="11" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Panneau de détail -->
                    <Border Grid.Column="1" Background="#FF10161F" CornerRadius="8" Margin="10,0,0,0" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Formulaire de pose d'un stockpile (clic droit / clic port-dépôt) -->
                                <Border Background="#FF22272F" CornerRadius="6" Padding="10" Margin="0,0,0,12"
                                        BorderBrush="#FF232C3A" BorderThickness="1"
                                        Visibility="{Binding Map.PlacementActive, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Map.PlacementTitle}" FontWeight="Bold" Foreground="White" FontSize="13"/>
                                        <TextBlock Text="{Binding Map.PlacementInfo}" Foreground="#FF94A1B2" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,3,0,8"/>
                                        <TextBlock Text="NOM" Style="{StaticResource Label}"/>
                                        <TextBox Text="{Binding Map.PlacementName, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6" Background="#FF10161F" Foreground="White"
                                                 BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"/>
                                        <TextBlock Text="CODE (optionnel)" Style="{StaticResource Label}" Margin="0,8,0,0"
                                                   Visibility="{Binding Map.PlacementUsesCode, Converter={StaticResource BoolToVis}}"/>
                                        <TextBox Text="{Binding Map.PlacementCode, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6" Background="#FF10161F" Foreground="White"
                                                 BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"
                                                 Visibility="{Binding Map.PlacementUsesCode, Converter={StaticResource BoolToVis}}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Content="✔ Créer" Style="{StaticResource FlatButton}" Background="#FF1F8A4C"
                                                    Padding="12,6" Click="OnMapPlacementCreate"/>
                                            <Button Content="Annuler" Style="{StaticResource FlatButton}" Background="#FF202A38"
                                                    Padding="12,6" Margin="8,0,0,0" Click="OnMapPlacementCancel"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Clique un hexagone pour voir ses villes, tes stockpiles et tes demandes sur place. Clic droit : poser un stockpile."
                                           Foreground="#FF5E6B7E" FontSize="12" TextWrapping="Wrap"
                                           Visibility="{Binding Map.NoSelection, Converter={StaticResource BoolToVis}}"/>

                                <StackPanel Visibility="{Binding Map.HasSelection, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding Map.SelectedName}" FontSize="17" FontWeight="Bold" Foreground="White"
                                               TextWrapping="Wrap" Margin="0,0,0,8"/>

                                    <TextBlock Text="VILLES" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                    <ItemsControl ItemsSource="{Binding Map.SelectedTowns}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,1">
                                                    <Ellipse Width="9" Height="9" Fill="{Binding Fill}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding TeamLabel}" Foreground="#FF94A1B2" FontSize="11"/>
                                                    <TextBlock Text="{Binding PanelName}" Foreground="#FFE9EDF3" FontSize="12"/>
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="STRUCTURES" Style="{StaticResource Label}" Margin="0,12,0,4"
                                               Visibility="{Binding Map.SelectedHasStructures, Converter={StaticResource BoolToVis}}"/>
                                    <ItemsControl ItemsSource="{Binding Map.SelectedStructureSummary}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Foreground="#FFE9EDF3" FontSize="12" Margin="0,1"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="STOCKPILES ICI" Style="{StaticResource Label}" Margin="0,12,0,4"
                                               Visibility="{Binding Map.SelectedHasStockpiles, Converter={StaticResource BoolToVis}}"/>
                                    <ItemsControl ItemsSource="{Binding Map.SelectedStockpiles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,1">
                                                    <TextBlock Foreground="#FFE9EDF3" FontSize="12">
                                                        <Run Text="📦 "/><Run Text="{Binding Name, Mode=OneWay}"/>
                                                        <Run Text="{Binding TypeLabel, Mode=OneWay}" Foreground="#FF94A1B2"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding ThreatLabel}" Foreground="#FFD23B41" FontSize="11" Margin="18,0,0,0"
                                                               Visibility="{Binding IsThreatened, Converter={StaticResource BoolToVis}}"/>
                                                    <StackPanel Orientation="Horizontal" Margin="18,3,0,2"
                                                                Visibility="{Binding CanManage, Converter={StaticResource BoolToVis}}">
                                                        <Button Content="📍 Déplacer" Style="{StaticResource FlatButton}" Background="#FF202A38"
                                                                FontSize="10.5" Padding="7,3" Click="OnMapMovePin"
                                                                ToolTip="Cliquer ensuite le nouvel emplacement sur la carte"/>
                                                        <Button Content="🗑" Style="{StaticResource FlatButton}" Background="#FF3A3030"
                                                                FontSize="10.5" Padding="7,3" Margin="6,0,0,0" Click="OnMapDeletePin"
                                                                ToolTip="Supprimer ce stockpile"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="DEMANDES ICI" Style="{StaticResource Label}" Margin="0,12,0,4"
                                               Visibility="{Binding Map.SelectedHasRequests, Converter={StaticResource BoolToVis}}"/>
                                    <ItemsControl ItemsSource="{Binding Map.SelectedRequests}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Foreground="#FFE9EDF3" FontSize="12" TextWrapping="Wrap" Margin="0,1"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <!-- ====================== CALCULATRICE LOGISTIQUE ====================== -->
            <Grid Visibility="{Binding IsCalculatorActive, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Calculatrice logistique" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Compose une liste d'items : le plan de production complet (crafts, récoltes, véhicules) se calcule tout seul — sans créer de demande."
                               Foreground="#FF94A1B2" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding Calculator}">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="ITEMS À PRODUIRE (item · quantité)" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="➕ Ajouter" Style="{StaticResource FlatButton}"
                                            Background="#FF2D63D8" Padding="14,6" Margin="6,0,0,0" Click="OnCalcAddItem"/>
                                    <TextBox DockPanel.Dock="Right" Width="90" Margin="6,0,0,0"
                                             Text="{Binding ItemQuantity, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" Padding="6" Background="#FF10161F" Foreground="White"
                                             BorderBrush="#FF232C3A" BorderThickness="1" CaretBrush="White"
                                             VerticalContentAlignment="Center"/>
                                    <ComboBox IsEditable="True" ItemsSource="{Binding ItemNames}" FontSize="14" Padding="6"
                                              Text="{Binding ItemName, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding Items}" Margin="0,10,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FF1F2937" CornerRadius="6" Padding="8,5" Margin="0,0,6,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="{Binding Icon}" Width="20" Height="20" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                    <TextBlock VerticalAlignment="Center" FontSize="12.5" Foreground="White">
                                                        <Run Text="{Binding Name, Mode=OneWay}"/>
                                                        <Run Text="{Binding Quantity, Mode=OneWay, StringFormat=' ×{0:N0}'}" Foreground="#FF53C272" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                    <Button Content="×" Style="{StaticResource FlatButton}" Background="#FF3A3030"
                                                            Padding="6,0" Margin="8,0,0,0" FontSize="11" Click="OnCalcRemoveItem"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <DockPanel Margin="0,6,0,0">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Content="🚚 Envoyer vers une demande" Style="{StaticResource FlatButton}"
                                                Background="#FF1F8A4C" Padding="12,6" Click="OnCalcSendResupply"
                                                Visibility="{Binding HasItems, Converter={StaticResource BoolToVis}}"
                                                ToolTip="Préremplit le brouillon d'une demande de ravitaillement avec cette liste"/>
                                        <Button Content="Vider" Style="{StaticResource FlatButton}" Background="#FF202A38"
                                                Padding="12,6" Margin="8,0,0,0" Click="OnCalcClear"
                                                Visibility="{Binding HasItems, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Status}" Foreground="#FF94A1B2" FontSize="12" VerticalAlignment="Center"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Visibility="{Binding HasPlan, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="🏭 CRAFTS À FAIRE" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding Crafts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FF1A222E" CornerRadius="6" Padding="8,6" Margin="0,0,0,4">
                                                <DockPanel>
                                                    <Border DockPanel.Dock="Right" Background="#FF232C3A" CornerRadius="4" Padding="7,2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Building}" Foreground="#FF6CA6F2" FontSize="11"/>
                                                    </Border>
                                                    <TextBlock DockPanel.Dock="Right" Foreground="#FFE9EDF3" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"
                                                               Text="{Binding QtyText}" FontWeight="SemiBold"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="{Binding Icon}" Width="22" Height="22" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="⛏ RÉCOLTES À FAIRE (ressources brutes)" Style="{StaticResource Label}" Margin="0,12,0,6"/>
                                <ItemsControl ItemsSource="{Binding Harvests}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FF1F2937" CornerRadius="6" Padding="9,6" Margin="0,0,6,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="{Binding Icon}" Width="20" Height="20" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock VerticalAlignment="Center" FontSize="12.5" Foreground="White">
                                                        <Run Text="{Binding Name, Mode=OneWay}"/>
                                                        <Run Text="{Binding QtyText, Mode=OneWay}" Foreground="#FFE8A33D" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Background="#FF131A24" CornerRadius="6" Margin="0,8,0,0" Padding="8,5">
                                    <TextBlock Text="{Binding VehiclesText, StringFormat='🚚 {0}'}" Foreground="#FFB6C2D1" FontSize="12"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ====================== PARAMÈTRES ====================== -->
            <Grid Visibility="{Binding IsSettingsActive, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Paramètres" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Settings.Status}" Foreground="#FF53C272" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Général -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel DataContext="{Binding Settings}">
                                <TextBlock Text="🖥 GÉNÉRAL" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                                <CheckBox Content="Lancer FoxholeLogiHub à l'ouverture de session Windows"
                                          IsChecked="{Binding StartWithWindows}" FontSize="12.5" Margin="0,0,0,6"/>
                                <CheckBox Content="Fermer la fenêtre = continuer en arrière-plan (icône de zone de notification, overlay et alertes actifs)"
                                          IsChecked="{Binding CloseToTray}" FontSize="12.5" Margin="0,0,0,6"/>
                                <CheckBox Content="Vérifier automatiquement les mises à jour au lancement"
                                          IsChecked="{Binding AutoCheckUpdates}" FontSize="12.5"/>
                                <DockPanel Margin="0,8,0,0">
                                    <Button DockPanel.Dock="Left" Content="🔄 Vérifier maintenant" Style="{StaticResource FlatButton}"
                                            Background="#FF2D63D8" Padding="10,5" Click="OnCheckUpdatesNow"/>
                                    <TextBlock Text="{Binding DataContext.UpdateStatus, RelativeSource={RelativeSource AncestorType=Window}}"
                                               Foreground="#FF94A1B2" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Notifications -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="🔔 NOTIFICATIONS WINDOWS" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                                <CheckBox Content="Activer les notifications (interrupteur principal)"
                                          IsChecked="{Binding NotificationsEnabled}" FontSize="12.5" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <StackPanel DataContext="{Binding Settings}" Margin="22,0,0,0"
                                            IsEnabled="{Binding DataContext.NotificationsEnabled, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <CheckBox Content="Demandes d'amis" IsChecked="{Binding NotifyFriendRequests}" FontSize="12" Margin="0,0,0,4"/>
                                    <CheckBox Content="Invitations de régiment" IsChecked="{Binding NotifyRegimentInvites}" FontSize="12" Margin="0,0,0,4"/>
                                    <CheckBox Content="Ravitaillement (nouvelles demandes, prises en charge, livraisons)" IsChecked="{Binding NotifyResupply}" FontSize="12" Margin="0,0,0,4"/>
                                    <CheckBox Content="Stock critique (à l'import)" IsChecked="{Binding NotifyCriticalStock}" FontSize="12" Margin="0,0,0,4"/>
                                    <CheckBox Content="Commande MPF terminée" IsChecked="{Binding NotifyMpfDone}" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Overlay & raccourcis -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel DataContext="{Binding Settings}">
                                <TextBlock Text="🗖 OVERLAY &amp; RACCOURCIS" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Import du stockpile en jeu" Foreground="#FF94A1B2" FontSize="11" Margin="0,0,0,3"/>
                                        <ComboBox ItemsSource="{Binding HotkeyOptions}" SelectedItem="{Binding ImportHotkey}"
                                                  FontSize="12.5" Padding="5"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Afficher/masquer l'overlay" Foreground="#FF94A1B2" FontSize="11" Margin="0,0,0,3"/>
                                        <ComboBox ItemsSource="{Binding HotkeyOptions}" SelectedItem="{Binding OverlayHotkey}"
                                                  FontSize="12.5" Padding="5"/>
                                    </StackPanel>
                                </UniformGrid>
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock DockPanel.Dock="Left" Text="Opacité de l'overlay" Foreground="#FF94A1B2"
                                               FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding OverlayOpacityText}" Foreground="White"
                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    <Slider Minimum="0.5" Maximum="1.0" Value="{Binding OverlayOpacity}"
                                            TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                </DockPanel>
                                <Button Content="↺ Réinitialiser les positions des fenêtres d'overlay" Style="{StaticResource FlatButton}"
                                        Background="#FF202A38" Padding="10,5" HorizontalAlignment="Left" Click="OnResetOverlayPositions"/>
                            </StackPanel>
                        </Border>

                        <!-- Carte & données -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel DataContext="{Binding Settings}">
                                <TextBlock Text="🗺 CARTE &amp; DONNÉES" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                                <CheckBox Content="Afficher les champs et mines de ressources dès l'ouverture de la carte"
                                          IsChecked="{Binding MapShowResourcesDefault}" FontSize="12.5" Margin="0,0,0,8"/>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Content="🗑 Vider" Style="{StaticResource FlatButton}"
                                            Background="#FF8E3438" Padding="10,4" Margin="8,0,0,0" Click="OnClearTileCache"/>
                                    <TextBlock Text="{Binding TileCacheText}" Foreground="#FF94A1B2" FontSize="12" VerticalAlignment="Center"/>
                                </DockPanel>
                                <Button Content="📂 Ouvrir le dossier de données (réglages, archives, cartes)" Style="{StaticResource FlatButton}"
                                        Background="#FF202A38" Padding="10,5" HorizontalAlignment="Left" Click="OnOpenDataFolder"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ====================== PORTE DE CONNEXION (au lancement) ====================== -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Background="#FF0A0E14"
                Visibility="{Binding Friends.NeedsLogin, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
                <Image Source="pack://application:,,,/Assets/logo.png" Width="130" Height="130"
                       RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,0,14"/>
                <TextBlock Text="FoxholeLogiHub" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Gestion logistique pour Foxhole" Foreground="#FF94A1B2" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                <Border Background="#FF10161F" CornerRadius="12" Padding="28,26" Margin="0,30,0,0"
                        BorderBrush="#FF232C3A" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Connecte-toi avec Steam pour accéder à toutes les fonctionnalités : amis, régiment, stockpiles et ravitaillement."
                                   Foreground="#FFB6C2D1" FontSize="13" TextWrapping="Wrap" TextAlignment="Center"/>
                        <Button Content="🎮  Se connecter avec Steam" HorizontalAlignment="Center" Margin="0,20,0,0"
                                Style="{StaticResource FlatButton}" Background="#FF2D63D8" Padding="22,11" FontSize="15"
                                Click="OnSteamLoginClick"/>
                        <TextBlock Text="{Binding Friends.Status}" Foreground="#FF94A1B2" FontSize="11"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,16,0,0"/>
                    </StackPanel>
                </Border>
                <TextBlock Text="La connexion ouvre ton navigateur (OpenID Steam) — aucun mot de passe n'est partagé avec l'app."
                           Foreground="#FF5E6B7E" FontSize="10" TextWrapping="Wrap" TextAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>
        </Border>
        </Grid>
      </Grid>
    </Border>
</Window>

<Window x:Class="FoxholeLogiHub.App.OverlayTakenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LogiHub Overlay — Prises en charge"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        Width="320" SizeToContent="Height" MaxHeight="560" ResizeMode="NoResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Border Background="#F20C1118" CornerRadius="10" BorderBrush="#FF232C3A" BorderThickness="1">
        <DockPanel Margin="10">

            <DockPanel DockPanel.Dock="Top" Background="Transparent" MouseLeftButtonDown="OnDragWindow" Margin="0,0,0,6">
                <Button DockPanel.Dock="Right" Content="✕" Click="OnCloseClick"
                        Background="Transparent" Foreground="#FF94A1B2" BorderThickness="0"
                        Padding="6,0" FontSize="13" Cursor="Hand"/>
                <TextBlock Text="🔧 Prises en charge" Foreground="White" FontWeight="Bold"
                           FontSize="12.5" VerticalAlignment="Center"/>
            </DockPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Aucune demande prise en charge." Foreground="#FF5E6B7E" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Resupply.TakenRequests.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding Resupply.TakenRequests}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FF161D28" CornerRadius="6" Padding="7,5" Margin="0,0,0,4">
                                    <StackPanel>
                                        <DockPanel>
                                            <Border DockPanel.Dock="Right" Background="#33FFFFFF" CornerRadius="3" Padding="4,1"
                                                    Visibility="{Binding ShowPriority, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding PriorityLabel}" Foreground="{Binding PriorityBrush}" FontSize="9" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="{Binding Title}" Foreground="White" FontSize="11.5" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                        <TextBlock Foreground="#FF5E6B7E" FontSize="9.5">
                                            <Run Text="{Binding LocationLabel, Mode=OneWay}"/>
                                            <Run Text="{Binding ClaimInfo, Mode=OneWay}" Foreground="#FF6CA6F2"/>
                                        </TextBlock>
                                        <ItemsControl ItemsSource="{Binding Items}" Margin="0,3,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,7,2">
                                                        <Image Source="{Binding Icon}" Width="13" Height="13" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding QtyText}" Foreground="#FFB6C2D1" FontSize="10" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="✓ Livré" Click="OnDeliverRequest" HorizontalAlignment="Right"
                                                Background="#FF1F8A4C" Foreground="White" BorderThickness="0"
                                                Padding="8,2" FontSize="10" Cursor="Hand" Margin="0,3,0,0"
                                                Visibility="{Binding CanComplete, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
